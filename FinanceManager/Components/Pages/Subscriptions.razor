@page "/subscriptions"
@rendermode InteractiveServer
@using CoinStack.Data.Entities
@inject CoinStack.Services.ISubscriptionService SubscriptionService

<PageTitle>Subscriptions</PageTitle>

<div>
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-white/90">Subscriptions</h2>

        <button
            class="inline-flex items-center justify-center rounded-lg bg-brand-500 px-4 py-3 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600"
            @onclick="OpenCreateModal">
            Add New
        </button>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
        <div class="border-b border-gray-100 px-6 py-5 dark:border-gray-800">
            <h3 class="text-base font-medium text-gray-800 dark:text-white/90">All Subscriptions</h3>
        </div>

        <div class="p-6">
            @if (_isLoading)
            {
                <div class="text-sm text-gray-500 dark:text-gray-400">Loading...</div>
            }
            else if (_subscriptions.Count == 0)
            {
                <div class="text-sm text-gray-500 dark:text-gray-400">No subscriptions yet.</div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full">
                        <thead>
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Service</th>
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Category</th>
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Cycle</th>
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Cost</th>
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Status</th>
                                <th class="px-4 py-3 text-right text-sm font-medium text-gray-500 dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                            @foreach (var subscription in _subscriptions)
                            {
                                <tr class="transition-colors hover:bg-gray-50 dark:hover:bg-white/[0.02]">
                                    <td class="px-4 py-4">
                                        <div class="flex items-center gap-3">
                                            <div
                                                class="relative flex h-9 w-9 items-center justify-center overflow-hidden rounded-full text-sm font-semibold text-white"
                                                style="background-color:@(GetSubscriptionColor(subscription));">
                                                @GetInitial(subscription.Name)
                                                <img src="@GetLogoUrl(subscription.Name)" 
                                                     class="absolute inset-0 h-full w-full object-contain bg-white" 
                                                     onerror="this.style.display='none'"
                                                     alt="@subscription.Name" />
                                            </div>
                                            <div class="text-sm font-medium text-gray-800 dark:text-white/90">@subscription.Name</div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 text-sm text-gray-700 dark:text-gray-300">@subscription.Category</td>
                                    <td class="px-4 py-4 text-sm text-gray-700 dark:text-gray-300">@subscription.Cycle</td>
                                    <td class="px-4 py-4 text-sm font-medium text-gray-800 dark:text-white/90">@subscription.Cost.ToString("0.00")</td>
                                    <td class="px-4 py-4">
                                        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium @GetStatusClasses(subscription.Status)">
                                            @subscription.Status
                                        </span>
                                    </td>
                                    <td class="px-4 py-4 text-right">
                                        <div class="flex items-center justify-end gap-1">
                                            <button
                                                @onclick="() => OpenEditModal(subscription)"
                                                class="text-gray-400 transition-colors hover:text-brand-500 dark:hover:text-brand-400"
                                                title="Edit">
                                                <svg class="fill-current" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M15.4901 3.21967C15.783 2.92678 16.2578 2.92678 16.5507 3.21967L20.7807 7.44967C21.0736 7.74256 21.0736 8.21744 20.7807 8.51033L9.53073 19.7603C9.38998 19.9011 9.19912 19.9803 9.00007 19.9803H4.77007C4.35586 19.9803 4.02007 19.6446 4.02007 19.2303V15.0003C4.02007 14.8013 4.09929 14.6104 4.24001 14.4697L15.4901 3.21967ZM5.52007 15.3109V18.4803H8.68951L19.1894 7.98033L16.0201 4.81099L5.52007 15.3109Z" fill="currentColor"/>
                                                </svg>
                                            </button>
                                            <button
                                                @onclick="() => DeleteSubscriptionAsync(subscription.Id)"
                                                class="text-gray-400 transition-colors hover:text-error-500 dark:hover:text-error-400"
                                                title="Delete">
                                                <svg class="fill-current" width="16" height="16" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M15.75 4.5H2.25M7.5 8.25V12.75M10.5 8.25V12.75M14.25 4.5V14.25C14.25 15.0784 13.5784 15.75 12.75 15.75H5.25C4.42157 15.75 3.75 15.0784 3.75 14.25V4.5M6 4.5V3C6 2.17157 6.67157 1.5 7.5 1.5H10.5C11.3284 1.5 12 2.17157 12 3V4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (_showModal)
    {
        <!-- Create/Edit Subscription Modal -->
        <div class="fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5 modal-backdrop-enter">
            <div class="fixed inset-0 h-full w-full bg-gray-400/50 backdrop-blur-[32px]" @onclick="CloseModal"></div>
            <div class="relative w-full max-w-[584px] rounded-3xl bg-white p-6 dark:bg-gray-900 lg:p-10 modal-panel-enter">
            <button
                @onclick="CloseModal"
                type="button"
                class="group absolute right-3 top-3 z-999 flex h-9.5 w-9.5 items-center justify-center rounded-full bg-gray-200 text-gray-500 transition-colors hover:bg-gray-300 hover:text-gray-500 dark:bg-gray-800 dark:hover:bg-gray-700 sm:right-6 sm:top-6 sm:h-11 sm:w-11">
                <svg
                    class="fill-current transition-colors group-hover:text-gray-600 dark:group-hover:text-gray-200"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg">
                    <path
                        fill-rule="evenodd"
                        clip-rule="evenodd"
                        d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z"
                        fill="" />
                </svg>
            </button>

            <form @onsubmit="SaveSubscriptionAsync">
                <h4 class="mb-6 text-lg font-medium text-gray-800 dark:text-white/90">@(_editingId.HasValue ? "Edit Subscription" : "New Subscription")</h4>

                <div class="grid grid-cols-1 gap-x-6 gap-y-5 sm:grid-cols-2">
                    <div class="col-span-1 sm:col-span-2">
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Service Name</label>
                        <input
                            type="text"
                            placeholder="Netflix"
                            @bind="_formName"
                            class="dark:bg-dark-900 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30 dark:focus:border-brand-800" />
                    </div>

                    <div class="col-span-1">
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Category</label>
                        <input
                            type="text"
                            placeholder="Entertainment"
                            @bind="_formCategory"
                            class="dark:bg-dark-900 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30 dark:focus:border-brand-800" />
                    </div>

                    <div class="col-span-1">
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Cost</label>
                        <input
                            type="number"
                            step="0.01"
                            inputmode="decimal"
                            @bind-value="_formCost"
                            @bind-value:event="oninput"
                            class="dark:bg-dark-900 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30 dark:focus:border-brand-800" />
                    </div>

                    <div class="col-span-1">
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Cycle</label>
                        <select
                            @bind="_formCycle"
                            class="dark:bg-dark-900 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-800">
                            @foreach (var value in Enum.GetValues<SubscriptionCycle>())
                            {
                                <option value="@value">@value</option>
                            }
                        </select>
                    </div>

                    <div class="col-span-1">
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Status</label>
                        <select
                            @bind="_formStatus"
                            class="dark:bg-dark-900 h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-800">
                            @foreach (var value in Enum.GetValues<SubscriptionStatus>())
                            {
                                <option value="@value">@value</option>
                            }
                        </select>
                    </div>

                    <div class="col-span-1">
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Color</label>
                        <input
                            type="color"
                            @bind="_formColorHex"
                            class="h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2 dark:border-gray-700" />
                    </div>
                </div>

                <div class="mt-6 flex w-full items-center justify-end gap-3">
                    <button
                        @onclick="CloseModal"
                        type="button"
                        class="flex w-full justify-center rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm font-medium text-gray-700 shadow-theme-xs transition-colors hover:bg-gray-50 hover:text-gray-800 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-white/[0.03] dark:hover:text-gray-200 sm:w-auto">
                        Close
                    </button>
                    <button
                        type="submit"
                        class="flex w-full justify-center rounded-lg bg-brand-500 px-4 py-3 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600 sm:w-auto">
                        @(_editingId.HasValue ? "Update" : "Save")
                    </button>
                </div>
            </form>
            </div>
        </div>
    }
</div>

@code {
    private readonly List<Subscription> _subscriptions = new();
    private bool _isLoading = true;
    private bool _showModal;

    private int? _editingId;
    private string _formName = "";
    private string _formCategory = "";
    private decimal _formCost;
    private SubscriptionCycle _formCycle = SubscriptionCycle.Monthly;
    private SubscriptionStatus _formStatus = SubscriptionStatus.Active;
    private string _formColorHex = "#11141D";

    protected override async Task OnInitializedAsync()
    {
        var items = await SubscriptionService.GetAllAsync();
        _subscriptions.Clear();
        _subscriptions.AddRange(items);
        _isLoading = false;
    }

    private void OpenCreateModal()
    {
        _editingId = null;
        _formName = "";
        _formCategory = "";
        _formCost = 0;
        _formCycle = SubscriptionCycle.Monthly;
        _formStatus = SubscriptionStatus.Active;
        _formColorHex = "#11141D";
        _showModal = true;
    }

    private void OpenEditModal(Subscription sub)
    {
        _editingId = sub.Id;
        _formName = sub.Name;
        _formCategory = sub.Category;
        _formCost = sub.Cost;
        _formCycle = sub.Cycle;
        _formStatus = sub.Status;
        _formColorHex = sub.CustomHexColor ?? sub.ColorHex ?? "#11141D";
        _showModal = true;
    }

    private static string GetInitial(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }

        return char.ToUpperInvariant(name.Trim()[0]).ToString();
    }

    private static string GetLogoUrl(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "";

        // specific mappings
        if (name.Equals("Xbox", StringComparison.OrdinalIgnoreCase) || name.Contains("Xbox Game Pass", StringComparison.OrdinalIgnoreCase))
            return "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f9/Xbox_one_logo.svg/2048px-Xbox_one_logo.svg.png";

        if (name.Equals("Playstation", StringComparison.OrdinalIgnoreCase) || name.Contains("PS Plus", StringComparison.OrdinalIgnoreCase))
            return "https://upload.wikimedia.org/wikipedia/commons/thumb/0/00/PlayStation_logo.svg/2560px-PlayStation_logo.svg.png";

        if (name.Contains("Office 365", StringComparison.OrdinalIgnoreCase) || name.Contains("Microsoft 365", StringComparison.OrdinalIgnoreCase))
            return "https://upload.wikimedia.org/wikipedia/commons/thumb/0/0e/Microsoft_365_%282022%29.svg/240px-Microsoft_365_%282022%29.svg.png";

        if (name.Contains("GitHub Copilot", StringComparison.OrdinalIgnoreCase) || name.Contains("Copilot", StringComparison.OrdinalIgnoreCase))
            return "https://upload.wikimedia.org/wikipedia/commons/2/2a/Microsoft_365_Copilot_Icon.svg"; // Fallback to Copilot icon if needed, or simply GitHub logic below

        if (name.Contains("GitHub", StringComparison.OrdinalIgnoreCase))
            return "https://github.com/fluidicon.png";

        // Simple heuristic: remove spaces and append .com
        var domain = new string(name.Where(c => char.IsLetterOrDigit(c)).ToArray()).ToLowerInvariant() + ".com";
        return $"https://logo.clearbit.com/{domain}";
    }

    private static string GetSubscriptionColor(Subscription subscription)
    {
        return subscription.CustomHexColor
            ?? subscription.ColorHex
            ?? "#11141D";
    }

    private static string GetStatusClasses(SubscriptionStatus status)
    {
        return status switch
        {
            SubscriptionStatus.Active => "bg-success-50 text-success-600 dark:bg-success-500/15 dark:text-success-500",
            SubscriptionStatus.Paused => "bg-gray-100 text-gray-700 dark:bg-white/[0.03] dark:text-gray-300",
            SubscriptionStatus.Cancelled => "bg-error-50 text-error-600 dark:bg-error-500/15 dark:text-error-500",
            _ => "bg-gray-100 text-gray-700 dark:bg-white/[0.03] dark:text-gray-300",
        };
    }

    private async Task SaveSubscriptionAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            return;
        }

        if (_editingId.HasValue)
        {
            var existing = _subscriptions.FirstOrDefault(s => s.Id == _editingId.Value);
            if (existing is not null)
            {
                existing.Name = _formName.Trim();
                existing.Category = _formCategory.Trim();
                existing.Cost = _formCost;
                existing.Cycle = _formCycle;
                existing.Status = _formStatus;
                existing.ColorHex = _formColorHex;
                existing.CustomHexColor = _formColorHex;
                await SubscriptionService.UpdateAsync(existing);
            }
        }
        else
        {
            var subscription = new Subscription
            {
                Name = _formName.Trim(),
                Category = _formCategory.Trim(),
                Cost = _formCost,
                Cycle = _formCycle,
                Status = _formStatus,
                ColorHex = _formColorHex,
                CustomHexColor = _formColorHex,
            };

            var created = await SubscriptionService.CreateAsync(subscription);
            _subscriptions.Insert(0, created);
        }

        _editingId = null;
        _formName = "";
        _formCategory = "";
        _formCost = 0;
        _formCycle = SubscriptionCycle.Monthly;
        _formStatus = SubscriptionStatus.Active;
        _formColorHex = "#11141D";
        _showModal = false;
    }

    private void CloseModal()
    {
        _showModal = false;
    }

    private async Task DeleteSubscriptionAsync(int id)
    {
        await SubscriptionService.DeleteAsync(id);
        _subscriptions.RemoveAll(s => s.Id == id);
    }
}