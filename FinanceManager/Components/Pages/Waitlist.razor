@page "/waitlist"
@rendermode InteractiveServer
@using CoinStack.Data.Entities

@inject IWaitlistService WaitlistService

<PageTitle>The Waitlist</PageTitle>

<div class="space-y-6">

    <!-- Header -->
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-semibold text-gray-800 dark:text-white/90">The Waitlist</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                Let time and your finances decide — not impulse.
            </p>
        </div>
        <button
            class="flex h-11 w-11 items-center justify-center rounded-full bg-brand-50 text-brand-600 transition-colors hover:bg-brand-100 dark:bg-brand-500/15 dark:text-brand-400 dark:hover:bg-brand-500/25"
            @onclick="OpenCreateModal"
            title="Add item">
            <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24"><path d="M12 4C11.5858 4 11.25 4.33579 11.25 4.75V11.25H4.75C4.33579 11.25 4 11.5858 4 12C4 12.4142 4.33579 12.75 4.75 12.75H11.25V19.25C11.25 19.6642 11.5858 20 12 20C12.4142 20 12.75 19.6642 12.75 19.25V12.75H19.25C19.6642 12.75 20 12.4142 20 12C20 11.5858 19.6642 11.25 19.25 11.25H12.75V4.75C12.75 4.33579 12.4142 4 12 4Z" fill="currentColor"/></svg>
        </button>
    </div>

    <!-- Score legend -->
    <div class="grid grid-cols-3 gap-3">
        <div class="rounded-2xl border border-error-200 bg-error-50 p-4 text-center dark:border-error-500/30 dark:bg-error-500/10">
            <p class="text-lg font-bold text-error-600 dark:text-error-400">0 – 39</p>
            <p class="mt-1 text-xs text-error-500 dark:text-error-400">Not a good time</p>
        </div>
        <div class="rounded-2xl border border-warning-200 bg-warning-50 p-4 text-center dark:border-warning-500/30 dark:bg-warning-500/10">
            <p class="text-lg font-bold text-warning-600 dark:text-warning-400">40 – 69</p>
            <p class="mt-1 text-xs text-warning-500 dark:text-warning-400">Maybe — think first</p>
        </div>
        <div class="rounded-2xl border border-success-200 bg-success-50 p-4 text-center dark:border-success-500/30 dark:bg-success-500/10">
            <p class="text-lg font-bold text-success-600 dark:text-success-400">70 – 100</p>
            <p class="mt-1 text-xs text-success-500 dark:text-success-400">You can afford it</p>
        </div>
    </div>

    <!-- List -->
    @if (_isLoading)
    {
        <div class="flex min-h-[220px] items-center justify-center rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
            <p class="text-sm text-gray-500 dark:text-gray-400">Loading...</p>
        </div>
    }
    else if (_items.Count == 0)
    {
        <div class="flex min-h-[220px] flex-col items-center justify-center gap-4 rounded-2xl border border-gray-200 bg-white p-10 text-center dark:border-gray-800 dark:bg-white/[0.03]">
            <p class="text-sm text-gray-500 dark:text-gray-400">Your waitlist is empty. Add something you want but aren't sure about yet.</p>
            <button @onclick="OpenCreateModal"
                    class="inline-flex items-center justify-center rounded-full bg-brand-500 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-brand-600">
                Add First Item
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 xl:grid-cols-3">
            @foreach (var item in _items)
            {
                var scoreColor = item.Score >= 70 ? "text-success-600 dark:text-success-400"
                               : item.Score >= 40 ? "text-warning-600 dark:text-warning-400"
                               : "text-error-600 dark:text-error-400";

                var scoreBg = item.Score >= 70 ? "bg-success-50 dark:bg-success-500/10"
                            : item.Score >= 40 ? "bg-warning-50 dark:bg-warning-500/10"
                            : "bg-error-50 dark:bg-error-500/10";

                var coolOffRemaining = item.CoolOffUntil - DateTime.UtcNow;
                var isTimerActive = !item.IsUnlocked && coolOffRemaining.TotalSeconds > 0;

                <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] flex flex-col gap-4">

                    <!-- Title row -->
                    <div class="flex items-start justify-between gap-2">
                        <div class="min-w-0">
                            <h4 class="truncate text-base font-semibold text-gray-800 dark:text-white/90">@item.Name</h4>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400 line-clamp-2">@item.Description</p>
                            }
                        </div>
                        <span class="shrink-0 rounded-full px-2.5 py-1 text-xs font-medium @PriorityBadge(item.Priority)">
                            @item.Priority
                        </span>
                    </div>

                    <!-- Cost + Score -->
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <p class="text-xs text-gray-500 dark:text-gray-400">Estimated cost</p>
                            <p class="text-xl font-bold text-gray-800 dark:text-white/90">@item.EstimatedCost.ToString("C")</p>
                        </div>
                        <div class="flex flex-col items-center rounded-xl @scoreBg px-4 py-2">
                            <p class="text-2xl font-extrabold @scoreColor">@item.Score</p>
                            <p class="text-[10px] font-medium @scoreColor">readiness</p>
                        </div>
                    </div>

                    <!-- Score bar -->
                    <div>
                        <div class="relative h-2 w-full rounded-full bg-gray-200 dark:bg-gray-700">
                            <div class="absolute left-0 top-0 h-full rounded-full transition-all duration-500
                                        @(item.Score >= 70 ? "bg-success-500" : item.Score >= 40 ? "bg-warning-500" : "bg-error-500")"
                                 style="width: @(Math.Min(item.Score, 100))%;">
                            </div>
                        </div>
                        <p class="mt-1 text-right text-[10px] text-gray-400 dark:text-gray-500">
                            Last evaluated @item.LastEvaluated.ToLocalTime().ToString("dd MMM, HH:mm")
                        </p>
                    </div>

                    <!-- Cool-off timer -->
                    @if (isTimerActive)
                    {
                        <div class="flex items-center gap-2 rounded-xl border border-warning-200 bg-warning-50 px-3 py-2 dark:border-warning-500/30 dark:bg-warning-500/10">
                            <svg class="shrink-0 text-warning-500" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                            <div class="min-w-0">
                                <p class="text-xs font-medium text-warning-700 dark:text-warning-400">Cooling off — locked</p>
                                <p class="text-[11px] text-warning-600 dark:text-warning-400">
                                    Unlocks @FormatTimeRemaining(coolOffRemaining)
                                </p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-center gap-2 rounded-xl border border-success-200 bg-success-50 px-3 py-2 dark:border-success-500/30 dark:bg-success-500/10">
                            <svg class="shrink-0 text-success-500" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <p class="text-xs font-medium text-success-700 dark:text-success-400">
                                Cool-off complete — do you still want this?
                            </p>
                        </div>
                    }

                    @if (item.EmotionAtTimeOfAdding.HasValue)
                    {
                        <div class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">
                            <span>Mood when added:</span>
                            <span class="font-medium text-gray-700 dark:text-gray-300">@item.EmotionAtTimeOfAdding</span>
                        </div>
                    }

                    <!-- Actions -->
                    <div class="flex items-center justify-between gap-2 border-t border-gray-100 pt-3 dark:border-gray-800">
                        <div class="flex gap-2">
                            <button @onclick="() => RefreshScoreAsync(item.Id)"
                                    class="inline-flex items-center gap-1 rounded-full border border-brand-300 bg-brand-50 px-3 py-1.5 text-xs font-medium text-brand-700 hover:bg-brand-100 dark:border-brand-500/40 dark:bg-brand-500/10 dark:text-brand-400"
                                    title="Recalculate score">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                                Recalculate
                            </button>

                            @if (item.IsUnlocked)
                            {
                                <button @onclick="() => PurchaseAsync(item.Id)"
                                        class="inline-flex items-center gap-1 rounded-full border border-success-300 bg-success-50 px-3 py-1.5 text-xs font-medium text-success-700 hover:bg-success-100 dark:border-success-500/40 dark:bg-success-500/10 dark:text-success-400">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                    Purchased
                                </button>
                            }
                        </div>

                        <div class="flex gap-1">
                            <button @onclick="() => OpenEditModal(item)"
                                    class="rounded-md p-1.5 text-gray-400 hover:text-brand-500 dark:hover:text-brand-400"
                                    title="Edit">
                                <svg class="fill-current" width="16" height="16" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M15.4901 3.21967C15.783 2.92678 16.2578 2.92678 16.5507 3.21967L20.7807 7.44967C21.0736 7.74256 21.0736 8.21744 20.7807 8.51033L9.53073 19.7603C9.38998 19.9011 9.19912 19.9803 9.00007 19.9803H4.77007C4.35586 19.9803 4.02007 19.6446 4.02007 19.2303V15.0003C4.02007 14.8013 4.09929 14.6104 4.24001 14.4697L15.4901 3.21967ZM5.52007 15.3109V18.4803H8.68951L19.1894 7.98033L16.0201 4.81099L5.52007 15.3109Z" fill="currentColor"/></svg>
                            </button>
                            <button @onclick="() => DeleteAsync(item.Id)"
                                    class="rounded-md p-1.5 text-gray-400 hover:text-error-500 dark:hover:text-error-400"
                                    title="Delete">
                                <svg class="fill-current" width="16" height="16" viewBox="0 0 18 18"><path d="M15.75 4.5H2.25M7.5 8.25V12.75M10.5 8.25V12.75M14.25 4.5V14.25C14.25 15.0784 13.5784 15.75 12.75 15.75H5.25C4.42157 15.75 3.75 15.0784 3.75 14.25V4.5M6 4.5V3C6 2.17157 6.67157 1.5 7.5 1.5H10.5C11.3284 1.5 12 2.17157 12 3V4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Create / Edit Modal -->
@if (_showModal)
{
    <div class="fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5 modal-backdrop-enter">
        <div class="fixed inset-0 h-full w-full bg-gray-400/50 backdrop-blur-[32px]" @onclick="CloseModal"></div>
        <div class="relative w-full max-w-[584px] rounded-3xl bg-white p-6 dark:bg-gray-900 lg:p-10 modal-panel-enter">

            <button @onclick="CloseModal" type="button"
                    class="group absolute right-3 top-3 z-999 flex h-9.5 w-9.5 items-center justify-center rounded-full bg-gray-200 text-gray-500 transition-colors hover:bg-gray-300 hover:text-gray-600 dark:bg-gray-800 dark:hover:bg-gray-700 sm:right-6 sm:top-6 sm:h-11 sm:w-11">
                <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z" fill=""/></svg>
            </button>

            <h4 class="mb-6 text-lg font-medium text-gray-800 dark:text-white/90">
                @(_editingId.HasValue ? "Edit Waitlist Item" : "Add to Waitlist")
            </h4>

            <form @onsubmit="SaveAsync" class="space-y-5">

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Item Name</label>
                    <input type="text" @bind="_formName" placeholder="e.g. Mechanical keyboard, New shoes…"
                           class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400" />
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Description <span class="text-gray-400">(optional)</span></label>
                    <textarea @bind="_formDescription" rows="2" placeholder="Why do you want this?"
                              class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Estimated Cost</label>
                        <input type="number" step="0.01" inputmode="decimal" @bind="_formCost" placeholder="0.00"
                               class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400" />
                    </div>
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Priority</label>
                        <select @bind="_formPriority"
                                class="h-11 w-full rounded-md border border-gray-300 bg-transparent px-4 py-2 text-sm text-gray-900 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-brand-400">
                            <option value="@WaitlistPriority.Low">Low</option>
                            <option value="@WaitlistPriority.Medium">Medium</option>
                            <option value="@WaitlistPriority.High">High</option>
                        </select>
                    </div>
                </div>

                @if (!_editingId.HasValue)
                {
                    <div>
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Cooling-off Period</label>
                        <div class="grid grid-cols-4 gap-2">
                            @foreach (var period in Enum.GetValues<CoolOffPeriod>())
                            {
                                var isActive = _formCoolOff == period;
                                <button type="button" @onclick="() => _formCoolOff = period"
                                        class="rounded-xl border py-2.5 text-sm font-medium transition-colors
                                               @(isActive ? "border-brand-500 bg-brand-50 text-brand-700 dark:bg-brand-500/20 dark:text-brand-300 dark:border-brand-500"
                                                          : "border-gray-200 bg-white text-gray-600 hover:border-brand-300 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400")">
                                    @CoolOffLabel(period)
                                </button>
                            }
                        </div>
                    </div>
                }

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">How are you feeling? <span class="text-gray-400">(optional)</span></label>
                    <select @bind="_formEmotion"
                            class="h-11 w-full rounded-md border border-gray-300 bg-transparent px-4 py-2 text-sm text-gray-900 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-brand-400">
                        <option value="">— Not specified —</option>
                        @foreach (var tag in Enum.GetValues<EmotionTag>())
                        {
                            <option value="@tag">@tag</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">URL <span class="text-gray-400">(optional)</span></label>
                    <input type="url" @bind="_formUrl" placeholder="https://…"
                           class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400" />
                </div>

                <div>
                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Reflection note <span class="text-gray-400">(optional)</span></label>
                    <textarea @bind="_formNote" rows="2" placeholder="Anything you want to remember about this decision…"
                              class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400"></textarea>
                </div>

                <div class="flex w-full items-center justify-end gap-3 pt-2">
                    <button @onclick="CloseModal" type="button"
                            class="flex w-full justify-center rounded-full border border-gray-300 bg-white px-6 py-2.5 text-sm font-medium text-gray-700 shadow-theme-xs transition-colors hover:bg-gray-50 hover:text-gray-900 dark:border-gray-600 dark:bg-transparent dark:text-gray-300 dark:hover:bg-white/[0.05] dark:hover:text-white sm:w-auto">
                        Cancel
                    </button>
                    <button type="submit"
                            class="flex w-full justify-center rounded-full bg-brand-500 px-6 py-2.5 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 sm:w-auto">
                        @(_editingId.HasValue ? "Save Changes" : "Add to Waitlist")
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@code {
    private readonly List<WaitlistItem> _items = [];
    private bool _isLoading = true;

    private bool _showModal;
    private int? _editingId;

    // Form fields
    private string _formName = "";
    private string? _formDescription;
    private decimal _formCost;
    private WaitlistPriority _formPriority = WaitlistPriority.Medium;
    private CoolOffPeriod _formCoolOff = CoolOffPeriod.Days7;
    private string? _formEmotion;
    private string? _formUrl;
    private string? _formNote;

    protected override async Task OnInitializedAsync()
    {
        await WaitlistService.EvaluateCoolOffsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        var items = await WaitlistService.GetAllAsync();
        _items.Clear();
        _items.AddRange(items);
        _isLoading = false;
    }

    private void OpenCreateModal()
    {
        _editingId = null;
        _formName = "";
        _formDescription = null;
        _formCost = 0;
        _formPriority = WaitlistPriority.Medium;
        _formCoolOff = CoolOffPeriod.Days7;
        _formEmotion = null;
        _formUrl = null;
        _formNote = null;
        _showModal = true;
    }

    private void OpenEditModal(WaitlistItem item)
    {
        _editingId = item.Id;
        _formName = item.Name;
        _formDescription = item.Description;
        _formCost = item.EstimatedCost;
        _formPriority = item.Priority;
        _formCoolOff = item.CoolOffPeriod;
        _formEmotion = item.EmotionAtTimeOfAdding?.ToString();
        _formUrl = item.Url;
        _formNote = item.ReflectionNote;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            return;
        }

        EmotionTag? emotion = null;
        if (!string.IsNullOrEmpty(_formEmotion) && Enum.TryParse<EmotionTag>(_formEmotion, out var parsed))
        {
            emotion = parsed;
        }

        if (_editingId.HasValue)
        {
            var item = await WaitlistService.GetByIdAsync(_editingId.Value);
            if (item is null)
            {
                return;
            }

            item.Name = _formName;
            item.Description = string.IsNullOrWhiteSpace(_formDescription) ? null : _formDescription;
            item.EstimatedCost = _formCost;
            item.Priority = _formPriority;
            item.EmotionAtTimeOfAdding = emotion;
            item.Url = string.IsNullOrWhiteSpace(_formUrl) ? null : _formUrl;
            item.ReflectionNote = string.IsNullOrWhiteSpace(_formNote) ? null : _formNote;

            await WaitlistService.UpdateAsync(item);
        }
        else
        {
            var item = new WaitlistItem
            {
                Name = _formName,
                Description = string.IsNullOrWhiteSpace(_formDescription) ? null : _formDescription,
                EstimatedCost = _formCost,
                Priority = _formPriority,
                CoolOffPeriod = _formCoolOff,
                EmotionAtTimeOfAdding = emotion,
                Url = string.IsNullOrWhiteSpace(_formUrl) ? null : _formUrl,
                ReflectionNote = string.IsNullOrWhiteSpace(_formNote) ? null : _formNote,
            };
            var created = await WaitlistService.CreateAsync(item);
            await WaitlistService.CalculateReadinessScoreAsync(created.Id);
        }

        CloseModal();
        await LoadAsync();
    }

    private async Task RefreshScoreAsync(int id)
    {
        await WaitlistService.CalculateReadinessScoreAsync(id);
        await LoadAsync();
    }

    private async Task PurchaseAsync(int id)
    {
        await WaitlistService.MarkPurchasedAsync(id);
        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        await WaitlistService.DeleteAsync(id);
        await LoadAsync();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string PriorityBadge(WaitlistPriority p) => p switch
    {
        WaitlistPriority.High   => "bg-error-50 text-error-600 dark:bg-error-500/15 dark:text-error-400",
        WaitlistPriority.Medium => "bg-warning-50 text-warning-600 dark:bg-warning-500/15 dark:text-warning-400",
        _                       => "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400"
    };

    private static string FormatTimeRemaining(TimeSpan t)
    {
        if (t.TotalDays >= 1)
        {
            return $"in {(int)t.TotalDays}d {t.Hours}h";
        }

        if (t.TotalHours >= 1)
        {
            return $"in {(int)t.TotalHours}h {t.Minutes}m";
        }

        return $"in {(int)t.TotalMinutes}m";
    }

    private static string CoolOffLabel(CoolOffPeriod period) => period switch
    {
        CoolOffPeriod.Hours24 => "24 hours",
        CoolOffPeriod.Days3   => "3 days",
        CoolOffPeriod.Days7   => "7 days",
        CoolOffPeriod.Days30  => "30 days",
        _                     => "7 days"
    };
}
