<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet 
        class="fixed inset-0 z-[9999] hidden h-screen w-full items-center justify-center bg-black/60 backdrop-blur-sm">
    
    <div class="components-reconnect-container max-w-[450px] rounded-lg border border-stroke bg-white shadow-default dark:border-strokedark dark:bg-boxdark">
        
        <!-- Reconnecting State (UX: Subtle & Non-intrusive) -->
        <div class="show-on-reconnect p-8 text-center">
            <div class="mb-6 flex justify-center">
                <!-- TailAdmin Style Spinner -->
                <div class="h-12 w-12 animate-spin rounded-full border-4 border-solid border-primary border-t-transparent"></div>
            </div>
            <h3 class="mb-3 text-2xl font-bold text-black dark:text-white">Connection Lost</h3>
            <p class="font-medium text-body">Attempting to reconnect to the server...</p>
        </div>

        <!-- Reconnect Failed State (UX: Alert/Action) -->
        <div class="show-on-failed hidden p-8 text-center">
            <div class="mb-6 flex justify-center text-danger">
                <div class="flex h-16 w-16 items-center justify-center rounded-full bg-red-100 dark:bg-red-900/20">
                     <svg class="h-8 w-8 fill-current" viewBox="0 0 20 20"><path d="M10 0C4.477 0 0 4.477 0 10s4.477 10 10 10 10-4.477 10-10S15.523 0 10 0zm1 15H9v-2h2v2zm0-4H9V5h2v6z"/></svg>
                </div>
            </div>
            <h3 class="mb-3 text-2xl font-bold text-black dark:text-white">Reconnect Failed</h3>
            <p class="mb-8 font-medium text-body">We couldn't reach the server. This might be due to your internet connection.</p>
            
            <button onclick="window.Blazor.reconnect()" 
                    class="flex w-full justify-center rounded bg-primary p-3 font-medium text-gray hover:bg-opacity-90 transition-all">
                Retry Connection
            </button>
        </div>

        <!-- Reconnect Rejected State (UX: Critical/Refresh) -->
        <div class="show-on-rejected hidden p-8 text-center">
            <h3 class="mb-3 text-2xl font-bold text-black dark:text-white">Session Expired</h3>
            <p class="mb-8 font-medium text-body">Your secure session has ended. Please refresh the page to continue.</p>
            <button onclick="location.reload()" 
                    class="flex w-full justify-center rounded bg-black p-3 font-medium text-white hover:bg-opacity-90 dark:bg-white dark:text-black">
                Refresh Page
            </button>
        </div>
    </div>
</dialog>


<style>
    #components-reconnect-modal[open],
    #components-reconnect-modal.components-reconnect-show,
    #components-reconnect-modal.components-reconnect-failed,
    #components-reconnect-modal.components-reconnect-rejected {
        display: flex !important;
        border: none;
        outline: none;
        background-color: rgba(0, 0, 0, 0.5);
    }

    .show-on-reconnect, .show-on-failed, .show-on-rejected { display: none; }

    #components-reconnect-modal.components-reconnect-show .show-on-reconnect { display: block; }
    #components-reconnect-modal.components-reconnect-failed .show-on-failed { display: block; }
    #components-reconnect-modal.components-reconnect-rejected .show-on-rejected { display: block; }
</style>