<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CoinStack.Mobile"
             x:Class="CoinStack.Mobile.App">
        <Application.Resources>
                <ResourceDictionary>

                        <!-- Design System Colors (Neobank-inspired) -->
                        <Color x:Key="Dark">#202020</Color>
                        <Color x:Key="Accent">#c9f158</Color>
                        <Color x:Key="Background">#f2f3f5</Color>
                        <Color x:Key="Surface">#ffffff</Color>
                        <Color x:Key="Border">#e5e7eb</Color>
                        <Color x:Key="Muted">#6b7280</Color>
                        <Color x:Key="Success">#047857</Color>
                        <Color x:Key="Danger">#b91c1c</Color>

                        <!-- Global Page Style -->
                        <Style TargetType="ContentPage"
                               ApplyToDerivedTypes="True">
                                <Setter Property="BackgroundColor"
                                        Value="{DynamicResource Background}"/>
                        </Style>

                        <!-- Navigation Bar Style -->
                        <Style TargetType="NavigationPage">
                                <Setter Property="BarBackgroundColor"
                                        Value="{DynamicResource Surface}"/>
                                <Setter Property="BarTextColor"
                                        Value="{DynamicResource Dark}"/>
                        </Style>

                        <!-- Typography -->
                        <Style TargetType="Label">
                                <Setter Property="TextColor"
                                        Value="{DynamicResource Dark}"/>
                                <Setter Property="FontFamily"
                                        Value="InterRegular"/>
                        </Style>

                        <!-- Button Styles -->
                        <Style TargetType="Button">
                                <Setter Property="BackgroundColor"
                                        Value="{DynamicResource Dark}"/>
                                <Setter Property="TextColor"
                                        Value="{DynamicResource Surface}"/>
                                <Setter Property="CornerRadius"
                                        Value="24"/>
                                <Setter Property="FontAttributes"
                                        Value="Bold"/>
                                <Setter Property="Padding"
                                        Value="16,12"/>
                                <Setter Property="FontFamily"
                                        Value="InterBold"/>
                                <Setter Property="HeightRequest"
                                        Value="48"/>
                        </Style>

                        <!-- Entry Styles -->
                        <Style TargetType="Entry">
                                <Setter Property="BackgroundColor"
                                        Value="{DynamicResource Surface}"/>
                                <Setter Property="TextColor"
                                        Value="{DynamicResource Dark}"/>
                                <Setter Property="PlaceholderColor"
                                        Value="{DynamicResource Muted}"/>
                                <Setter Property="FontFamily"
                                        Value="InterRegular"/>
                                <Setter Property="FontSize"
                                        Value="14"/>
                        </Style>

                        <!-- Editor Styles -->
                        <Style TargetType="Editor">
                                <Setter Property="BackgroundColor"
                                        Value="{DynamicResource Surface}"/>
                                <Setter Property="TextColor"
                                        Value="{DynamicResource Dark}"/>
                                <Setter Property="PlaceholderColor"
                                        Value="{DynamicResource Muted}"/>
                                <Setter Property="FontFamily"
                                        Value="InterRegular"/>
                                <Setter Property="FontSize"
                                        Value="14"/>
                        </Style>

                        <!-- Picker Styles -->
                        <Style TargetType="Picker">
                                <Setter Property="TextColor"
                                        Value="{DynamicResource Dark}"/>
                                <Setter Property="TitleColor"
                                        Value="{DynamicResource Muted}"/>
                                <Setter Property="FontFamily"
                                        Value="InterRegular"/>
                                <Setter Property="FontSize"
                                        Value="14"/>
                                <Setter Property="BackgroundColor"
                                        Value="{DynamicResource Surface}"/>
                        </Style>

                        <!-- DatePicker Styles -->
                        <Style TargetType="DatePicker">
                                <Setter Property="TextColor"
                                        Value="{StaticResource Dark}"/>
                                <Setter Property="FontFamily"
                                        Value="InterRegular"/>
                                <Setter Property="FontSize"
                                        Value="14"/>
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource Surface}"/>
                        </Style>

                        <!-- Slider Styles -->
                        <Style TargetType="Slider">
                                <Setter Property="MinimumTrackColor"
                                        Value="{StaticResource Dark}"/>
                                <Setter Property="MaximumTrackColor"
                                        Value="{StaticResource Border}"/>
                                <Setter Property="ThumbColor"
                                        Value="{StaticResource Dark}"/>
                        </Style>

                        <!-- Switch Styles -->
                        <Style TargetType="Switch">
                                <Setter Property="OnColor"
                                        Value="{StaticResource Dark}"/>
                                <Setter Property="ThumbColor"
                                        Value="{StaticResource Surface}"/>
                        </Style>

                        <!-- ProgressBar Styles -->
                        <Style TargetType="ProgressBar">
                                <Setter Property="ProgressColor"
                                        Value="{StaticResource Accent}"/>
                        </Style>

                        <!-- Card style -->
                        <Style x:Key="Card"
                               TargetType="Border">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource Surface}"/>
                                <Setter Property="StrokeShape"
                                        Value="RoundRectangle 24"/>
                                <Setter Property="Stroke"
                                        Value="Transparent"/>
                                <Setter Property="StrokeThickness"
                                        Value="0"/>
                                <Setter Property="Padding"
                                        Value="20"/>
                        </Style>

                </ResourceDictionary>
        </Application.Resources>
</Application>
