@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Routing
@using CoinStack.Services
@using CoinStack.Data.Entities
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IGameLoopService GameLoop
@inject IScoringService ScoringService
@inject IReflectionService ReflectionService
@inject ISettingsService SettingsService

<!-- ===== Page Wrapper Start ===== -->
<div class="flex h-screen overflow-hidden">
    <!-- ===== Sidebar Start ===== -->
    <NavMenu SidebarToggle="@_sidebarToggle" SidebarToggleChanged="@OnSidebarToggleChanged" />
    <!-- ===== Sidebar End ===== -->

    <!-- ===== Content Area Start ===== -->
    <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
        <div class="@(_sidebarToggle ? "fixed z-50 h-screen w-full bg-gray-900/50 xl:hidden" : "hidden")" @onclick="() => _sidebarToggle = false"></div>

        <!-- ===== Header Start ===== -->
        <header
            class="sticky top-0 z-99999 flex w-full border-gray-200 bg-white xl:border-b dark:border-gray-800 dark:bg-gray-900">
            <div class="flex grow flex-col items-center justify-between xl:flex-row xl:px-6">
                <div class="flex w-full items-center justify-between gap-2 border-b border-gray-200 px-3 py-3 sm:gap-4 lg:py-4 xl:justify-normal xl:border-b-0 xl:px-0 dark:border-gray-800">
                    <button
                        class="@(_sidebarToggle ? "xl:bg-transparent dark:xl:bg-transparent bg-gray-100 dark:bg-gray-800" : "") z-99999 flex h-10 w-10 items-center justify-center rounded-lg border-gray-200 text-gray-500 xl:h-11 xl:w-11 xl:border dark:border-gray-800 dark:text-gray-400"
                        @onclick="() => _sidebarToggle = !_sidebarToggle" @onclick:stopPropagation>
                        @if (!_sidebarToggle)
                        {
                            <i class="fa-solid fa-bars xl:hidden text-xl"></i>
                        }
                        else
                        {
                            <i class="fa-solid fa-xmark xl:hidden text-xl"></i>
                        }
                    </button>
                    <a href="/" class="flex items-center gap-2 xl:hidden">
                        <img class="h-8" src="/tailadmin/src/images/logo/logo.png" alt="CoinStack" />
                        <span class="text-xl font-bold text-gray-800 dark:text-white">CoinStack</span>
                    </a>
                </div>

                <!-- Right Header: Score, Streak, Reflect, DarkMode -->
                <div class="hidden w-full items-center justify-end gap-4 px-5 py-4 xl:flex xl:px-0">
                    <div class="flex items-center gap-4">
                        <div class="flex h-10 items-center gap-2 rounded-full bg-gray-100 px-4 dark:bg-gray-800">
                            <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Net Saved</span>
                            <span class="text-xs font-bold text-gray-800 dark:text-white/90">@FormatC0(_netSaved)</span>
                        </div>

                        <div class="flex h-10 items-center gap-2 rounded-full bg-gray-100 px-4 dark:bg-gray-800">
                            <span class="text-xs font-semibold text-gray-500 dark:text-gray-400">Total Spent</span>
                            <span class="text-xs font-bold text-gray-800 dark:text-white/90">@FormatC0(_totalSpent)</span>
                        </div>

                        <!-- Score -->
                         <div class="flex h-10 items-center gap-2 rounded-full bg-brand-50 px-4 dark:bg-brand-500/15">
                             <span class="text-brand-500 dark:text-brand-400">
                                <i class="fa-solid fa-star text-base"></i>
                             </span>
                             <span class="text-xs font-bold text-brand-500 dark:text-brand-400">@_totalScore pts</span>
                         </div>

                        <!-- Daily Streak Widget -->
                         <div class="flex h-10 items-center gap-2 rounded-full bg-gray-100 px-4 dark:bg-gray-800">
                             <div class="@_streakColorClass">
                                 <i class="fa-solid fa-fire text-base"></i>
                             </div>
                             <span class="text-xs font-bold @_streakColorClass">@_streakCount Day Streak</span>
                         </div>

                        <!-- Reflection Trigger -->
                        @if (_pendingReflection != null)
                        {
                            <button @onclick="() => _showReflectionModal = true" class="relative flex items-center justify-center h-10 w-10 rounded-full bg-warning-50 text-warning-500 hover:bg-warning-100 dark:bg-warning-500/15 dark:text-warning-400" title="Time to Reflect">
                                <span class="absolute right-0 top-0 flex h-3 w-3">
                                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-warning-400 opacity-75"></span>
                                  <span class="relative inline-flex h-3 w-3 rounded-full bg-warning-500"></span>
                                </span>
                                <i class="fa-solid fa-lightbulb text-base"></i>
                            </button>
                        }

                            </div>
                        </div>
            </div>
        </header>
        <!-- ===== Header End ===== -->

        <!-- ===== Main Content Start ===== -->
        <main x-ignore>
            <div class="mx-auto w-full max-w-[1600px] p-4 md:p-6 2xl:p-10">
                @Body
            </div>
        </main>
        <!-- ===== Main Content End ===== -->
    </div>
    <!-- ===== Content Area End ===== -->
</div>
<!-- ===== Page Wrapper End ===== -->

@code {
    private int _streakCount;
    private string _streakColorClass = "text-gray-500";
    private int _totalScore;
    private Reflection? _pendingReflection;
    private bool _showReflectionModal;
    private decimal _totalSpent;
    private decimal _netSaved;
    private string _currency = "USD";

    private string _reflectionResponse = "";
    private string _reframeResponse = "";
    private int _moodBefore = 5;
    private int _moodAfter = 5;
    private EmotionTag? _selectedEmotion;
    private readonly List<string> _selectedDistortions = [];
    private static readonly string[] DistortionOptions =
    [
        "All-or-nothing thinking",
        "Catastrophizing",
        "Emotional reasoning",
        "Scarcity/fear-based thinking",
        "Social comparison/FOMO"
    ];
    private List<EmotionSpendPattern> _emotionPatterns = [];
    private bool _sidebarToggle = false;

    private void OnSidebarToggleChanged(bool value)
    {
        _sidebarToggle = value;
    }

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        await LoadStateAsync();
    }

    private async Task LoadStateAsync()
    {
        try 
        {
            var settings = await SettingsService.GetAsync();
            _currency = settings.Currency;
            CurrencyFormatting.ApplyCurrency(_currency);

            var transactions = await TransactionService.GetAllAsync();
            var totalIncome = transactions.Where(t => t.Type == TransactionType.Income).Sum(t => t.Amount);
            _totalSpent = transactions.Where(t => t.Type == TransactionType.Expense).Sum(t => t.Amount);
            _netSaved = totalIncome - _totalSpent;

            var state = await GameLoop.GetCurrentStateAsync();
            var streak = state.Streaks.FirstOrDefault(s => s.Type == StreakType.DailyCheckIn);
            _streakCount = streak?.CurrentCount ?? 0;
            _totalScore = state.TotalScore;
            _pendingReflection = state.PendingReflection;

            if (_streakCount >= 7) _streakColorClass = "text-warning-500";
            else if (_streakCount >= 3) _streakColorClass = "text-brand-500";
            else _streakColorClass = "text-gray-500";

            if (_pendingReflection is not null)
            {
                _emotionPatterns = await ReflectionService.GetEmotionPatternsAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading state in layout: {ex.Message}");
        }
    }

    private async Task SubmitReflectionAsync()
    {
        if (_pendingReflection is null || string.IsNullOrWhiteSpace(_reflectionResponse))
        {
            return;
        }

        try
        {
            await ReflectionService.CompleteReflectionAsync(
                _pendingReflection.Id,
                BuildFinalReflectionResponse(),
                _moodBefore,
                _moodAfter,
                _selectedEmotion);

            var settings = await SettingsService.GetAsync();
            if (settings.EnableScoring)
            {
                await ScoringService.AddScoreEventAsync(
                    3,
                    ScoreChangeReason.ReflectionCompleted,
                    "Completed a reflection");
            }

            _showReflectionModal = false;
            _reflectionResponse = "";
            _reframeResponse = "";
            _selectedDistortions.Clear();
            _selectedEmotion = null;
            _moodBefore = 5;
            _moodAfter = 5;
            await LoadStateAsync();
        }
        catch (Exception ex)
        {
             Console.WriteLine($"Error submitting reflection: {ex.Message}");
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = RefreshTailadminAsync();
        }

        return Task.CompletedTask;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(RefreshTailadminAsync);
    }

    private async Task RefreshTailadminAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("tailadminBlazor.refresh");
        }
        catch
        {
            // Ignore: can happen during prerender or if JS not ready yet.
        }
    }

    private void ToggleDistortion(string distortion)
    {
        if (_selectedDistortions.Contains(distortion))
        {
            _selectedDistortions.Remove(distortion);
            return;
        }

        _selectedDistortions.Add(distortion);
    }

    private string BuildFinalReflectionResponse()
    {
        var response = _reflectionResponse.Trim();
        var hasDistortions = _selectedDistortions.Count > 0;
        var hasReframe = !string.IsNullOrWhiteSpace(_reframeResponse);

        if (!hasDistortions && !hasReframe)
        {
            return response;
        }

        var distortionsLine = hasDistortions
            ? string.Join(", ", _selectedDistortions)
            : "None selected";

        var reframeLine = hasReframe
            ? _reframeResponse.Trim()
            : "No reframe entered";

        return $"{response}\n\nCBT Reframe\n- Distortions: {distortionsLine}\n- Reframe: {reframeLine}";
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private string FormatC0(decimal amount) => CurrencyFormatting.FormatCurrency(amount, _currency, 0);
}

<!-- Reflection Modal -->
@if (_showReflectionModal && _pendingReflection != null)
{
    <div class="fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5 bg-gray-900/50 backdrop-blur-sm" style="z-index: 99999;">
        <div class="fixed inset-0 h-full w-full" @onclick="() => _showReflectionModal = false"></div>
        <div class="relative w-full max-w-[380px] rounded-3xl bg-white p-5 shadow-2xl dark:bg-gray-800">
            <button
                @onclick="() => _showReflectionModal = false"
                type="button"
                class="absolute right-3 top-3 flex h-7 w-7 items-center justify-center rounded-full bg-gray-100 text-gray-500 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-400 dark:hover:bg-gray-600">
                <i class="fa-solid fa-xmark text-sm"></i>
            </button>

            <div class="text-center mb-4">
                <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-full bg-warning-100 text-warning-600 dark:bg-warning-900/30 dark:text-warning-400">
                    <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M9 21c0 .5.5 1 1 1h4c.5 0 1-.5 1-1v-1H9v1zm3-19C8.1 2 5 5.1 5 9c0 2.4 1.2 4.5 3 5.7V17c0 .5.5 1 1 1h6c.5 0 1-.5 1-1v-2.3c1.8-1.3 3-3.4 3-5.7 0-3.9-3.1-7-7-7z"/></svg>
                </div>
                <h3 class="text-base font-bold text-gray-800 dark:text-white">Time to Reflect</h3>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">@_pendingReflection.Prompt</p>
            </div>

            @if (_emotionPatterns.Count > 0)
            {
                var top = _emotionPatterns[0];
                <div class="mb-3 rounded-xl bg-brand-50 px-3 py-2 text-xs text-brand-700 dark:bg-brand-500/10 dark:text-brand-400">
                    <span class="font-semibold">Pattern:</span> @top.Insight
                </div>
            }

            <div class="space-y-4">
                <div>
                    <p class="mb-2 text-xs font-medium text-gray-600 dark:text-gray-400">How are you feeling?</p>
                    <div class="flex flex-wrap gap-1.5">
                        @foreach (var tag in Enum.GetValues<EmotionTag>())
                        {
                            var isSelected = _selectedEmotion == tag;
                            var (emoji, colorClass) = tag switch
                            {
                                EmotionTag.Proud     => ("🌟", "bg-success-50 text-success-700 border-success-300 dark:bg-success-500/15 dark:text-success-400"),
                                EmotionTag.Motivated => ("💪", "bg-success-50 text-success-700 border-success-300 dark:bg-success-500/15 dark:text-success-400"),
                                EmotionTag.Excited   => ("🎉", "bg-brand-50 text-brand-700 border-brand-300 dark:bg-brand-500/15 dark:text-brand-400"),
                                EmotionTag.Stressed  => ("😰", "bg-error-50 text-error-700 border-error-300 dark:bg-error-500/15 dark:text-error-400"),
                                EmotionTag.Anxious   => ("😟", "bg-error-50 text-error-700 border-error-300 dark:bg-error-500/15 dark:text-error-400"),
                                EmotionTag.Impulsive => ("⚡", "bg-warning-50 text-warning-700 border-warning-300 dark:bg-warning-500/15 dark:text-warning-400"),
                                EmotionTag.Tired     => ("😴", "bg-warning-50 text-warning-700 border-warning-300 dark:bg-warning-500/15 dark:text-warning-400"),
                                EmotionTag.Bored     => ("😑", "bg-warning-50 text-warning-700 border-warning-300 dark:bg-warning-500/15 dark:text-warning-400"),
                                EmotionTag.Guilty    => ("😔", "bg-orange-50 text-orange-700 border-orange-300 dark:bg-orange-500/15 dark:text-orange-400"),
                                _                    => ("😐", "bg-gray-100 text-gray-600 border-gray-300 dark:bg-gray-700 dark:text-gray-300")
                            };
                            <button type="button"
                                    @onclick="() => _selectedEmotion = isSelected ? null : tag"
                                    class="inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-xs font-medium transition-all @colorClass @(isSelected ? "ring-2 ring-offset-1 ring-brand-400" : "")">
                                @emoji @tag
                            </button>
                        }
                    </div>
                </div>

                <div>
                    <div class="flex justify-between text-xs mb-1 text-gray-500 dark:text-gray-400">
                        <span>Mood Before</span>
                        <span>@_moodBefore / 10</span>
                    </div>
                    <input type="range" min="1" max="10" @bind="_moodBefore" class="h-1.5 w-full cursor-pointer appearance-none rounded-lg bg-gray-200 dark:bg-gray-700" />
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-medium text-gray-700 dark:text-gray-300">Your Thoughts</label>
                    <textarea
                        @bind="_reflectionResponse"
                        rows="3"
                        placeholder="How are you feeling about your finances?"
                        class="w-full rounded-lg border border-gray-200 bg-transparent px-3 py-2 text-sm text-gray-800 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 dark:border-gray-700 dark:text-white">
                    </textarea>
                </div>

                <div class="rounded-xl border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-900/40">
                    <p class="mb-2 text-xs font-semibold text-gray-700 dark:text-gray-300">Thought Reframe (CBT)</p>
                    <p class="mb-2 text-[11px] text-gray-500 dark:text-gray-400">Select any thinking patterns you notice, then write a more balanced replacement thought.</p>

                    <div class="mb-3 flex flex-wrap gap-1.5">
                        @foreach (var distortion in DistortionOptions)
                        {
                            var selected = _selectedDistortions.Contains(distortion);
                            <button type="button"
                                    @onclick="() => ToggleDistortion(distortion)"
                                    class="rounded-full border px-2.5 py-1 text-[11px] font-medium transition-all @(selected ? "border-brand-300 bg-brand-50 text-brand-700 dark:border-brand-500/40 dark:bg-brand-500/15 dark:text-brand-400" : "border-gray-300 bg-white text-gray-600 hover:border-gray-400 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300")">
                                @distortion
                            </button>
                        }
                    </div>

                    <textarea
                        @bind="_reframeResponse"
                        rows="2"
                        placeholder="Balanced thought example: 'I can wait 48 hours and reassess this against my budget goals.'"
                        class="w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 dark:border-gray-700 dark:bg-gray-800 dark:text-white">
                    </textarea>
                </div>

                <div>
                    <div class="flex justify-between text-xs mb-1 text-gray-500 dark:text-gray-400">
                        <span>Mood After</span>
                        <span>@_moodAfter / 10</span>
                    </div>
                    <input type="range" min="1" max="10" @bind="_moodAfter" class="h-1.5 w-full cursor-pointer appearance-none rounded-lg bg-gray-200 dark:bg-gray-700" />
                </div>

                <button
                    @onclick="SubmitReflectionAsync"
                    class="flex w-full items-center justify-center gap-2 rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-medium text-white hover:bg-brand-600 transition-colors">
                    Complete Reflection (+3 pts)
                </button>
            </div>
        </div>
    </div>
}