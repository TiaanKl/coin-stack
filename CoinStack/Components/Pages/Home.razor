@page "/"
@rendermode InteractiveServer
@using CoinStack.Data.Entities
@using CoinStack.Services
@inject ITransactionService TransactionService
@inject IGameLoopService GameLoop
@inject ISettingsService SettingsService
@inject ISavingsService SavingsService
@inject ISubscriptionService SubscriptionService
@inject IBucketService BucketService
@inject IMoneyFormatter MoneyFormatter

<PageTitle>CoinStack</PageTitle>

<div class="grid grid-cols-12 gap-4 md:gap-6">
    <div class="col-span-12 grid grid-cols-1 gap-4 xl:grid-cols-2">
        <div
            class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-white/[0.03]">
            <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
                <div class="text-center sm:text-left">
                    <h3 class="text-lg font-bold text-gray-800 dark:text-white/90">Monthly Budget Remaining</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                        @FormatC(MonthlyBudgetSpent) spent of @FormatC(MonthlyBudgetLimit)
                    </p>
                    <div class="mt-3 flex flex-wrap gap-2">
                        <span
                            class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300">
                            <span class="inline-block h-2 w-2 rounded-full bg-gray-400"></span>
                            Planned: @FormatC(_totalPlanned)
                        </span>
                        <span
                            class="inline-flex items-center gap-1.5 rounded-full bg-error-50 px-3 py-1 text-xs font-medium text-error-600 dark:bg-error-500/15 dark:text-error-400">
                            <span class="inline-block h-2 w-2 rounded-full bg-error-500"></span>
                            Spent: @FormatC(MonthlyBudgetSpent)
                        </span>
                        <span
                            class="inline-flex items-center gap-1.5 rounded-full bg-success-50 px-3 py-1 text-xs font-medium text-success-600 dark:bg-success-500/15 dark:text-success-400">
                            <span class="inline-block h-2 w-2 rounded-full bg-success-500"></span>
                            Available: @FormatC(MonthlyBudgetRemaining)
                        </span>
                    </div>
                </div>

                <BudgetDonut BudgetLimit="@MonthlyBudgetLimit" Spent="@MonthlyBudgetSpent" Size="240" />
            </div>
        </div>

        <div
            class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-white/[0.03]">
            <h3 class="text-lg font-bold text-gray-800 dark:text-white/90">Reserves On Hand</h3>
            <div class="mt-4 space-y-3">
                <div class="flex items-center justify-between rounded-xl bg-gray-50 px-4 py-3 dark:bg-gray-800">
                    <span class="text-sm text-gray-600 dark:text-gray-300">Savings</span>
                    <span
                    class="text-sm font-semibold text-success-600 dark:text-success-500">@FormatC(_savingsState.Available)</span>
                </div>
                <div class="flex items-center justify-between rounded-xl bg-gray-50 px-4 py-3 dark:bg-gray-800">
                    <span class="text-sm text-gray-600 dark:text-gray-300">Emergency Fund</span>
                    <span
                    class="text-sm font-semibold text-warning-600 dark:text-warning-400">@FormatC(_savingsState.EmergencyAvailable)</span>
                </div>
                <div class="flex items-center justify-between rounded-xl bg-gray-50 px-4 py-3 dark:bg-gray-800">
                    <span class="text-sm text-gray-600 dark:text-gray-300">Total Reserved</span>
                    <span class="text-sm font-semibold text-gray-800 dark:text-white">@FormatC(ReservesOnHand)</span>
                </div>
            </div>

            @if (_settings.ShowReserveAwareBudget)
            {
                <p
                    class="mt-4 text-sm font-semibold @(ReserveAwareBudgetRemaining >= 0 ? "text-success-600 dark:text-success-500" : "text-error-600 dark:text-error-500")">
                    Reserve-aware available: @FormatC(ReserveAwareBudgetRemaining)
                </p>
            }
        </div>
    </div>

    <div class="col-span-12 xl:col-span-6">
        <div class="h-full rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
            <h3 class="mb-4 font-bold text-gray-800 dark:text-white/90">Daily Spending</h3>
            <ApexChart TItem="DailyData" Height="300" Title="" Options="_dailyChartOptions">
                <ApexPointSeries TItem="DailyData" Items="_spendingData" Name="Spending"
                                 XValue="@(x => x.Date.ToShortDateString())" YValue="@(x => x.Amount)" SeriesType="SeriesType.Bar"
                                 Color="@(GetSpendingColor())" />
            </ApexChart>
        </div>
    </div>

    <div class="col-span-12 xl:col-span-6">
        <div class="h-full rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
            <h3 class="mb-4 font-bold text-gray-800 dark:text-white/90">Money Trend</h3>
            <ApexChart TItem="DailyData" Height="300" Title="" Options="_moneyTrendChartOptions">
                <ApexPointSeries TItem="DailyData" Items="_moneyTrendData" Name="Money Trend"
                                 XValue="@(x => x.Date.ToShortDateString())" YValue="@(x => x.Amount)" SeriesType="SeriesType.Line"
                                 Color="@(GetMoneyTrendColor())" />
            </ApexChart>
        </div>
    </div>

    <div class="col-span-12">
        <div class="h-full rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
            <div class="mb-4 flex items-center justify-between gap-3">
                <h3 class="font-bold text-gray-800 dark:text-white/90">Predictive Cash Flow (30 days)</h3>
                <span
                    class="rounded-lg bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300">Income:
                    @FormatC(_projectedIncomeIn30Days) · Expense: @FormatC(_projectedExpenseIn30Days) · Net:
                    @FormatC(_projectedBalanceIn30Days)</span>
                </div>
                <ApexChart TItem="ForecastData" Height="260" Title="" Options="_forecastChartOptions">
                    <ApexPointSeries TItem="ForecastData" Items="_forecastData" Name="Projected Net"
                                     XValue="@(x => x.Date.ToShortDateString())" YValue="@(x => x.ProjectedNetBalance)"
                                     SeriesType="SeriesType.Line" Color="@(GetForecastNetColor())" />
                    <ApexPointSeries TItem="ForecastData" Items="_forecastData" Name="Projected Income"
                                     XValue="@(x => x.Date.ToShortDateString())" YValue="@(x => x.ProjectedIncomeCumulative)"
                                     SeriesType="SeriesType.Line" Color="@(GetForecastIncomeColor())" />
                    <ApexPointSeries TItem="ForecastData" Items="_forecastData" Name="Projected Expense"
                                     XValue="@(x => x.Date.ToShortDateString())" YValue="@(x => x.ProjectedExpenseCumulative)"
                                     SeriesType="SeriesType.Line" Color="@(GetForecastExpenseColor())" />
                </ApexChart>
            </div>
        </div>

        <div class="col-span-12 grid grid-cols-1 gap-4 md:gap-6 xl:grid-cols-2">
            <div
                class="flex h-full min-h-[360px] flex-col rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
                <div class="px-5 pt-5">
                    <h3 class="mb-1 font-bold text-gray-800 dark:text-white/90">Recent Transactions</h3>
                </div>
                <div class="flex-1 overflow-y-auto p-5">
                    @if (_transactions.Count == 0)
                    {
                        <div
                            class="flex h-full min-h-[280px] items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800">
                            <p class="text-sm text-gray-500 dark:text-gray-400">No data available</p>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-3">
                            @foreach (var tx in _transactions.OrderByDescending(x => x.OccurredAtUtc))
                            {
                                <div
                                    class="flex items-center justify-between rounded-lg border border-gray-100 p-3 dark:border-gray-800">
                                    <div>
                                        <p class="text-sm font-medium text-gray-800 dark:text-white/90">@tx.Description</p>
                                        <p class="text-xs text-gray-500 dark:text-gray-400">@tx.OccurredAtUtc.ToString("dd MMM")</p>
                                    </div>
                                    <p
                                        class="text-sm font-semibold @(tx.Type == TransactionType.Income ? "text-success-600 dark:text-success-500" : "text-gray-800 dark:text-white/90")">
                                        @(tx.Type == TransactionType.Income ? "+" : "-")@FormatC(tx.Amount)
                                    </p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div
                class="flex h-full min-h-[360px] flex-col rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
                <h3 class="mb-4 font-bold text-gray-800 dark:text-white/90">Recent Score Activity</h3>
                <div class="flex-1 overflow-y-auto">
                    @if (_state.RecentEvents.Count == 0)
                    {
                        <div
                            class="flex h-full min-h-[280px] items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800">
                            <p class="text-sm text-gray-500 dark:text-gray-400">No data available</p>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-3">
                            @foreach (var evt in _state.RecentEvents)
                            {
                                <div
                                    class="flex items-center justify-between rounded-lg border border-gray-100 p-3 dark:border-gray-800">
                                    <div>
                                        <p class="text-sm font-medium text-gray-800 dark:text-white/90">@evt.Description</p>
                                        <p class="text-xs text-gray-500 dark:text-gray-400">@evt.Reason •
                                            @evt.CreatedAtUtc.ToString("dd MMM, HH:mm")</p>
                                        </div>
                                        <span
                                            class="text-sm font-semibold @(evt.Points >= 0 ? "text-success-600 dark:text-success-500" : "text-error-600 dark:text-error-500")">@(evt.Points
                                                                                                                                                                >= 0 ? "+" : "")@evt.Points</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

@code
{
    private GameState _state = new();

    private AppSettings _settings = new();
    private SavingsState _savingsState = new();
    private decimal _budgetSpent;
    private decimal _totalPlanned;

    private decimal MonthlyBudgetLimit => _settings.MonthlyIncome;

    private decimal MonthlyBudgetSpent => _budgetSpent;

    private decimal MonthlyBudgetRemaining => MonthlyBudgetLimit - MonthlyBudgetSpent;

    private decimal ReservesOnHand => _savingsState.Available + _savingsState.EmergencyAvailable;

    private decimal ReserveAwareBudgetRemaining => MonthlyBudgetRemaining - ReservesOnHand;

    private readonly List<Transaction> _transactions = [];
    private readonly List<Transaction> _recentTransactions = [];
    private readonly List<DailyData> _spendingData = [];
    private readonly List<DailyData> _moneyTrendData = [];
    private readonly List<ForecastData> _forecastData = [];
    private readonly ApexChartOptions<DailyData> _dailyChartOptions = BuildDailyChartOptions();
    private readonly ApexChartOptions<DailyData> _moneyTrendChartOptions = BuildDailyChartOptions();
    private readonly ApexChartOptions<ForecastData> _forecastChartOptions = BuildForecastChartOptions();

    private decimal _projectedBalanceIn30Days;
    private decimal _projectedIncomeIn30Days;
    private decimal _projectedExpenseIn30Days;
    private bool _spendingIsPlaceholder;
    private bool _moneyTrendIsPlaceholder;
    private bool _forecastIsPlaceholder;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetAsync();
        CurrencyFormatting.ApplyCurrency(_settings.Currency);
        await TransactionService.ApplyAutoDeductionsForBudgetPeriodAsync(_settings.MonthStartDay, DateTime.UtcNow);
        await TransactionService.ApplyAutoIncomeForBudgetPeriodAsync(_settings.MonthStartDay, _settings.MonthlyIncome,
DateTime.UtcNow);
        _budgetSpent = await TransactionService.GetExpenseTotalForBudgetPeriodAsync(_settings.MonthStartDay, DateTime.UtcNow);
        _savingsState = await SavingsService.GetStateAsync();

        var buckets = await BucketService.GetAllAsync();
        var spentAmounts = await BucketService.GetSpentAmountsForPeriodAsync(_settings.MonthStartDay, DateTime.UtcNow);
        _totalPlanned = buckets.Sum(b => Math.Max(0, b.AllocatedAmount - spentAmounts.GetValueOrDefault(b.Id)));

        await GameLoop.ProcessDailyCheckInAsync();
        _state = await GameLoop.GetCurrentStateAsync();

        var now = DateTime.UtcNow;
        var transactions = await TransactionService.GetFromDateAsync(now.AddDays(-120));

        _transactions.Clear();
        _transactions.AddRange(transactions);

        PrepareChartData();
    }

    private void PrepareChartData()
    {
        _spendingData.Clear();
        _moneyTrendData.Clear();
        _forecastData.Clear();
        _spendingIsPlaceholder = false;
        _moneyTrendIsPlaceholder = false;
        _forecastIsPlaceholder = false;

        var now = DateTime.UtcNow.Date;

        if (_transactions.Count == 0)
        {
            _projectedIncomeIn30Days = 0;
            _projectedExpenseIn30Days = 0;
            _projectedBalanceIn30Days = 0;
            SeedDailyAxes(now, _spendingData, 30);
            SeedDailyAxes(now, _moneyTrendData, 30);
            SeedForecastAxes(now);
            _spendingIsPlaceholder = true;
            _moneyTrendIsPlaceholder = true;
            _forecastIsPlaceholder = true;
            return;
        }

        var thirtyDaysAgo = now.AddDays(-30);

        _spendingData.AddRange(_transactions
            .Where(t => t.Type == TransactionType.Expense && t.OccurredAtUtc >= thirtyDaysAgo)
            .GroupBy(t => t.OccurredAtUtc.Date)
            .Select(g => new DailyData(g.Key, g.Sum(t => t.Amount)))
            .OrderBy(x => x.Date));

        if (_spendingData.Count == 0)
        {
            SeedDailyAxes(now, _spendingData, 30);
            _spendingIsPlaceholder = true;
        }

        // Use the settings-based daily income as the floor so the trend
        // is meaningful even when income isn't logged as transactions.
        var settingsDailyIncome = _settings.MonthlyIncome / 30m;

        decimal runningBalance = 0m;

        for (var i = 30; i >= 0; i--)
        {
            var date = now.AddDays(-i).Date;

            var loggedIncome = _transactions
                .Where(t => t.Type == TransactionType.Income && t.OccurredAtUtc.Date == date)
                .Sum(t => t.Amount);

            var dailyExpense = _transactions
                .Where(t => t.Type == TransactionType.Expense && t.OccurredAtUtc.Date == date)
                .Sum(t => t.Amount);

            var dailyIncome = Math.Max(loggedIncome, settingsDailyIncome);

            runningBalance += dailyIncome - dailyExpense;
            _moneyTrendData.Add(new DailyData(date, runningBalance));
        }

        _moneyTrendIsPlaceholder = _moneyTrendData.All(x => x.Amount == 0);

        BuildForecast(now, runningBalance);
    }

    private void BuildForecast(DateTime today, decimal currentBalance)
    {
        var periodStart = today.AddDays(-90);
        var recent = _transactions.Where(t => t.OccurredAtUtc.Date >= periodStart && t.OccurredAtUtc.Date <= today).ToList();

        // Use settings income as the reliable daily income floor so
        // the forecast doesn't collapse to zero when income isn't
        // logged as transactions.
        var settingsDailyIncome = _settings.MonthlyIncome / 30m;

        if (recent.Count == 0)
        {
            _projectedIncomeIn30Days = 0;
            _projectedExpenseIn30Days = 0;
            _projectedBalanceIn30Days = currentBalance;

            if (settingsDailyIncome > 0)
            {
                var bal = currentBalance;
                var income = 0m;

                for (var day = 1; day <= 30; day++)
                {
                    income += settingsDailyIncome;
                    bal += settingsDailyIncome;
                    _forecastData.Add(new ForecastData(today.AddDays(day), income, 0m, bal));
                }

                _projectedIncomeIn30Days = income;
                _projectedBalanceIn30Days = bal;
            }
            else
            {
                SeedForecastAxes(today);
                _forecastIsPlaceholder = true;
            }
            return;
        }

        var dailyIncome = new Dictionary<DateTime, decimal>();
        var dailyExpense = new Dictionary<DateTime, decimal>();
        var weekdayExpenseTotals = new Dictionary<DayOfWeek, decimal>();
        var weekdayDayCounts = new Dictionary<DayOfWeek, int>();

        for (var date = periodStart; date <= today; date = date.AddDays(1))
        {
            dailyIncome[date] = 0m;
            dailyExpense[date] = 0m;
            weekdayExpenseTotals.TryAdd(date.DayOfWeek, 0m);
            weekdayDayCounts.TryAdd(date.DayOfWeek, 0);
            weekdayDayCounts[date.DayOfWeek]++;
        }

        foreach (var tx in recent)
        {
            var date = tx.OccurredAtUtc.Date;
            if (tx.Type == TransactionType.Income)
            {
                dailyIncome[date] += tx.Amount;
            }
            else if (tx.Type == TransactionType.Expense)
            {
                dailyExpense[date] += tx.Amount;
            }
        }

        foreach (var day in dailyExpense.Keys)
        {
            weekdayExpenseTotals[day.DayOfWeek] += dailyExpense[day];
        }

        var globalExpenseAvg = dailyExpense.Values.DefaultIfEmpty(0m).Average();

        var recent14Start = today.AddDays(-13);
        var recent14ExpenseAvg = dailyExpense.Where(x => x.Key >= recent14Start).Select(x =>
x.Value).DefaultIfEmpty(0m).Average();

        // For income projection: use the max of the logged average
        // and the settings daily rate so income is never undercounted.
        var loggedIncomeAvg = dailyIncome.Values.DefaultIfEmpty(0m).Average();
        var projectedDailyIncomeRate = Math.Max(loggedIncomeAvg, settingsDailyIncome);

        var projection = currentBalance;
        var projectedIncomeCum = 0m;
        var projectedExpenseCum = 0m;

        for (var day = 1; day <= 30; day++)
        {
            var forecastDate = today.AddDays(day);
            var weekday = forecastDate.DayOfWeek;

            var weekdayExpenseAvg = weekdayDayCounts[weekday] > 0
                ? weekdayExpenseTotals[weekday] / weekdayDayCounts[weekday]
                : globalExpenseAvg;

            var projectedDailyExpense = (weekdayExpenseAvg * 0.70m) + (recent14ExpenseAvg * 0.30m);

            projectedDailyIncomeRate = Math.Max(projectedDailyIncomeRate, 0m);
            projectedDailyExpense = Math.Max(projectedDailyExpense, 0m);

            projectedIncomeCum += projectedDailyIncomeRate;
            projectedExpenseCum += projectedDailyExpense;
            projection += projectedDailyIncomeRate - projectedDailyExpense;
            _forecastData.Add(new ForecastData(forecastDate, projectedIncomeCum, projectedExpenseCum, projection));
        }

        _projectedIncomeIn30Days = projectedIncomeCum;
        _projectedExpenseIn30Days = projectedExpenseCum;
        _projectedBalanceIn30Days = projection;
        _forecastIsPlaceholder = _forecastData.All(x =>
            x.ProjectedIncomeCumulative == 0 &&
            x.ProjectedExpenseCumulative == 0 &&
            x.ProjectedNetBalance == 0);
    }

    private string FormatC(decimal amount) => CurrencyFormatting.FormatCurrency(amount, _settings.Currency, 2);
    private string FormatC0(decimal amount) => CurrencyFormatting.FormatCurrency(amount, _settings.Currency, 0);

    private static void SeedDailyAxes(DateTime endDate, List<DailyData> target, int daysBack)
    {
        target.Clear();
        for (var i = daysBack; i >= 0; i--)
        {
            target.Add(new DailyData(endDate.AddDays(-i), 0));
        }
    }

    private void SeedForecastAxes(DateTime today)
    {
        _forecastData.Clear();
        for (var day = 1; day <= 30; day++)
        {
            _forecastData.Add(new ForecastData(today.AddDays(day), 0, 0, 0));
        }
    }

    private string GetSpendingColor() => _spendingIsPlaceholder ? "rgba(60,80,224,0.25)" : "#3C50E0";
    private string GetMoneyTrendColor() => _moneyTrendIsPlaceholder ? "rgba(16,185,129,0.35)" : "#10B981";
    private string GetForecastNetColor() => _forecastIsPlaceholder ? "rgba(60,80,224,0.35)" : "#3C50E0";
    private string GetForecastIncomeColor() => _forecastIsPlaceholder ? "rgba(16,185,129,0.35)" : "#10B981";
    private string GetForecastExpenseColor() => _forecastIsPlaceholder ? "rgba(245,158,11,0.35)" : "#F59E0B";

    private static ApexChartOptions<DailyData> BuildDailyChartOptions()
    {
        return new ApexChartOptions<DailyData>
        {
            Chart = new Chart
            {
                Animations = new Animations { Enabled = false },
                Toolbar = new Toolbar { Show = false },
                Zoom = new Zoom { Enabled = false }
            },
            DataLabels = new DataLabels { Enabled = false }
        };
    }

    private static ApexChartOptions<ForecastData> BuildForecastChartOptions()
    {
        return new ApexChartOptions<ForecastData>
        {
            Chart = new Chart
            {
                Animations = new Animations { Enabled = false },
                Toolbar = new Toolbar { Show = false },
                Zoom = new Zoom { Enabled = false }
            },
            DataLabels = new DataLabels { Enabled = false }
        };
    }

    public sealed record DailyData(DateTime Date, decimal Amount);
    public sealed record ForecastData(DateTime Date, decimal ProjectedIncomeCumulative, decimal ProjectedExpenseCumulative,
decimal ProjectedNetBalance);
}
