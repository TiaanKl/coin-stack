@page "/"
@rendermode InteractiveServer
@using CoinStack.Data.Entities
@using CoinStack.Services
@inject ITransactionService TransactionService
@inject IGameLoopService GameLoop
@inject IScoringService ScoringService
@inject IReflectionService ReflectionService
@inject IGoalService GoalService
@inject ISettingsService SettingsService
@inject ISavingsService SavingsService
@inject ISubscriptionService SubscriptionService
@inject IBucketService BucketService
@inject IMoneyFormatter MoneyFormatter

<PageTitle>CoinStack</PageTitle>

<div class="grid grid-cols-12 gap-4 md:gap-6">
    <div class="col-span-12">
        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-white/[0.03]">
            <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
                <div class="text-center sm:text-left">
                    <h3 class="text-lg font-bold text-gray-800 dark:text-white/90">Monthly Budget Remaining</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                        @FormatC(MonthlyBudgetSpent) spent of @FormatC(MonthlyBudgetLimit)
                    </p>
                </div>

                <BudgetDonut BudgetLimit="@MonthlyBudgetLimit" Spent="@MonthlyBudgetSpent" Size="260" />
            </div>
        </div>
    </div>

    <div class="col-span-12 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <div class="h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
            <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Amount</h4>
            <div class="mt-2 flex items-baseline gap-2">
                <span class="text-3xl font-bold text-gray-800 dark:text-white">@FormatC(_monthlyTotal)</span>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Income available this month</p>
        </div>

        <div class="h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
            <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400">Pre-allocated</h4>
            <div class="mt-2 flex items-baseline gap-2">
                <span class="text-3xl font-bold text-gray-800 dark:text-white">@FormatC(_preAllocated)</span>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Reserved for buckets &amp; subscriptions</p>
        </div>

        <div class="h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
            <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400">Other Spending</h4>
            <div class="mt-2 flex items-baseline gap-2">
                <span class="text-3xl font-bold text-gray-800 dark:text-white">@FormatC(_nonBucketSpent)</span>
            </div>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Expenses outside buckets</p>
        </div>

        <div class="h-full rounded-2xl border @(_remaining >= 0 ? "border-brand-200 bg-brand-50 dark:border-brand-900/30 dark:bg-brand-900/10" : "border-error-200 bg-error-50 dark:border-error-900/30 dark:bg-error-900/10") p-6 shadow-sm">
            <h4 class="text-sm font-medium @(_remaining >= 0 ? "text-brand-600 dark:text-brand-400" : "text-error-600 dark:text-error-400")">Remaining</h4>
            <div class="mt-2 flex items-baseline gap-2">
                <span class="text-3xl font-bold @(_remaining >= 0 ? "text-brand-700 dark:text-brand-300" : "text-error-700 dark:text-error-300")">@FormatC(_remaining)</span>
            </div>
            <p class="mt-1 text-xs @(_remaining >= 0 ? "text-brand-600/80 dark:text-brand-400/80" : "text-error-600/80 dark:text-error-400/80")">Available after allocations &amp; spending</p>
        </div>
    </div>

    <div class="col-span-12 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <a href="/savings" class="block h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-gray-800 dark:bg-gray-900">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-brand-50 text-brand-500 dark:bg-brand-900/20">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            </div>
            <div class="mt-4">
                <h4 class="text-2xl font-bold text-gray-800 dark:text-white">@FormatC0(_savingsState.Available)</h4>
                <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">Savings</span>
                <div class="mt-2 space-y-0.5 text-xs text-gray-500 dark:text-gray-400">
                    <p>@FormatC0(_savingsThisMonth) saved this month</p>
                    @if (_savingsFallbackThisMonth > 0)
                    {
                        <p class="text-warning-600 dark:text-warning-400">@FormatC0(_savingsFallbackThisMonth) used as fallback</p>
                    }
                </div>
            </div>
        </a>

        <div class="h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-blue-50 text-blue-500 dark:bg-blue-900/20">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            </div>
            <div class="mt-4">
                <h4 class="text-2xl font-bold text-gray-800 dark:text-white">@(_summaryData.FirstOrDefault(x => x.Label == "Spending") is { } sp ? FormatC0(sp.Amount) : FormatC0(0))</h4>
                <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Spent</span>
            </div>
        </div>

        <div class="h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-orange-50 text-orange-500 dark:bg-orange-900/20">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"></path></svg>
            </div>
            <div class="mt-4">
                @{ var streak = _state.Streaks.FirstOrDefault(x => x.Type == StreakType.DailyCheckIn); }
                <h4 class="text-2xl font-bold text-gray-800 dark:text-white">@(streak?.CurrentCount ?? 0) Days</h4>
                <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Check-in Streak</span>
            </div>
        </div>

        <div class="h-full rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-purple-50 text-purple-500 dark:bg-purple-900/20">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
            </div>
            <div class="mt-4">
                <h4 class="text-2xl font-bold text-gray-800 dark:text-white">@_state.TotalScore</h4>
                <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Financial Score</span>
            </div>
        </div>
    </div>

    <div class="col-span-12 xl:col-span-8">
        <div class="h-full rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
            <h3 class="mb-4 font-bold text-gray-800 dark:text-white/90">Spending Buckets</h3>
            @if (_state.BucketStatuses.Count == 0)
            {
                <div class="flex min-h-[260px] items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800">
                    <p class="text-sm text-gray-500 dark:text-gray-400">No data available</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    @foreach (var bucket in _state.BucketStatuses)
                    {
                        <div class="rounded-xl border border-gray-100 p-4 dark:border-gray-800">
                            <div class="mb-3 flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <div class="h-3 w-3 rounded-full" style="background-color: @(bucket.ColorHex ?? "#6577F3");"></div>
                                    <h4 class="text-sm font-medium text-gray-800 dark:text-white/90">@bucket.Name</h4>
                                </div>
                                <span class="text-xs font-medium @(bucket.IsOverBudget ? "text-error-600 dark:text-error-500" : "text-success-600 dark:text-success-500")">
                                    @(bucket.IsOverBudget ? "Over" : "On Track")
                                </span>
                            </div>
                            <div class="mb-2 flex items-end justify-between">
                                <span class="text-lg font-bold text-gray-800 dark:text-white/90">@FormatC(bucket.Spent)</span>
                                                                                <span class="text-xs text-gray-500 dark:text-gray-400">/ @FormatC(bucket.Allocated)</span>
                            </div>
                            <div class="relative h-2 w-full rounded-full bg-gray-200 dark:bg-gray-800">
                                <div class="absolute left-0 top-0 h-full rounded-full @(bucket.IsOverBudget ? "bg-error-500" : bucket.PercentUsed > 80 ? "bg-warning-500" : "bg-success-500")" style="width: @(Math.Min(bucket.PercentUsed, 100).ToString("F0"))%;"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-span-12 xl:col-span-4">
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
            <div class="px-5 pt-5">
                <h3 class="mb-1 font-bold text-gray-800 dark:text-white/90">Recent Transactions</h3>
            </div>
            <div class="min-h-[320px] p-5">
                @if (_recentTransactions.Count == 0)
                {
                    <div class="flex h-full min-h-[280px] items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800">
                        <p class="text-sm text-gray-500 dark:text-gray-400">No data available</p>
                    </div>
                }
                else
                {
                    <div class="space-y-3">
                        @foreach (var tx in _recentTransactions)
                        {
                            <div class="flex items-center justify-between rounded-lg border border-gray-100 p-3 dark:border-gray-800">
                                <div>
                                    <p class="text-sm font-medium text-gray-800 dark:text-white/90">@tx.Description</p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">@tx.OccurredAtUtc.ToString("dd MMM")</p>
                                </div>
                                <p class="text-sm font-semibold @(tx.Type == TransactionType.Income ? "text-success-600 dark:text-success-500" : "text-gray-800 dark:text-white/90")">
                                    @(tx.Type == TransactionType.Income ? "+" : "-")@FormatC(tx.Amount)
                                </p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-span-12">
        <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
            <h3 class="mb-4 font-bold text-gray-800 dark:text-white/90">Recent Score Activity</h3>
            @if (_state.RecentEvents.Count == 0)
            {
                <div class="flex min-h-[240px] items-center justify-center rounded-lg bg-gray-50 dark:bg-gray-800">
                    <p class="text-sm text-gray-500 dark:text-gray-400">No data available</p>
                </div>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var evt in _state.RecentEvents.Take(8))
                    {
                        <div class="flex items-center justify-between rounded-lg border border-gray-100 p-3 dark:border-gray-800">
                            <div>
                                <p class="text-sm font-medium text-gray-800 dark:text-white/90">@evt.Description</p>
                                <p class="text-xs text-gray-500 dark:text-gray-400">@evt.Reason • @evt.CreatedAtUtc.ToString("dd MMM, HH:mm")</p>
                            </div>
                            <span class="text-sm font-semibold @(evt.Points >= 0 ? "text-success-600 dark:text-success-500" : "text-error-600 dark:text-error-500")">@(evt.Points >= 0 ? "+" : "")@evt.Points</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-span-12">
        <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
            <h3 class="mb-4 font-bold text-gray-800 dark:text-white/90">Vision Board Goals</h3>
        <div class="grid grid-cols-1 gap-6 xl:grid-cols-12">
            <div class="xl:col-span-4">
                <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
                    <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">Create a savings goal with milestones and rewards.</p>
                    <form class="space-y-4" @onsubmit="CreateGoalAsync">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Goal name</label>
                            <input @bind="_goalName" type="text" placeholder="New Car"
                                   class="h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-800" />
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Target amount</label>
                            <input @bind-value="_goalTargetAmount" @bind-value:event="oninput" type="number" min="0" step="0.01"
                                   class="h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-800" />
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Current amount</label>
                            <input @bind-value="_goalCurrentAmount" @bind-value:event="oninput" type="number" min="0" step="0.01"
                                   class="h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-800" />
                        </div>
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Target date (optional)</label>
                            <InputDate TValue="DateTime?" @bind-Value="_goalTargetDateUtc"
                                       class="h-11 w-full rounded-lg border border-gray-300 bg-transparent px-4 py-2.5 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-800" />
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_goalFormError))
                        {
                            <div class="rounded-lg border border-error-200 bg-error-50 px-3 py-2 text-sm text-error-700 dark:border-error-500/40 dark:bg-error-500/10 dark:text-error-400">@_goalFormError</div>
                        }
                        <button type="submit" class="inline-flex w-full items-center justify-center rounded-lg bg-brand-500 px-4 py-3 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-600">Create vision board</button>
                    </form>
                </div>
            </div>

            <div class="xl:col-span-8">
                @if (_goals.Count == 0)
                {
                    <div class="flex min-h-[280px] items-center justify-center rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-white/[0.03]">
                        <p class="text-sm text-gray-500 dark:text-gray-400">No data available</p>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                        @foreach (var goal in _goals.OrderByDescending(x => x.CreatedAtUtc))
                        {
                            var progressPercent = goal.TargetAmount <= 0 ? 0m : Math.Clamp(goal.CurrentAmount / goal.TargetAmount * 100m, 0m, 100m);
                            <div class="flex h-full flex-col rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
                                <div class="mb-3 flex items-start justify-between gap-3">
                                    <div>
                                        <h4 class="text-base font-semibold text-gray-800 dark:text-white/90">@goal.Name</h4>
                                        <p class="text-xs text-gray-500 dark:text-gray-400">@(goal.TargetDateUtc.HasValue ? $"Target: {goal.TargetDateUtc.Value:dd MMM yyyy}" : "No target date")</p>
                                    </div>
                                    <span class="rounded-lg px-2 py-1 text-xs font-semibold @(goal.Status == GoalStatus.Completed ? "bg-success-50 text-success-600 dark:bg-success-500/15 dark:text-success-500" : "bg-brand-50 text-brand-600 dark:bg-brand-500/15 dark:text-brand-400")">@goal.Status</span>
                                </div>

                                <div class="mb-3 flex items-end justify-between">
                                    <span class="text-xl font-bold text-gray-800 dark:text-white/90">@FormatC(goal.CurrentAmount)</span>
                                                                                        <span class="text-xs text-gray-500 dark:text-gray-400">of @FormatC(goal.TargetAmount)</span>
                                </div>

                                <div class="relative mb-4 h-2.5 w-full rounded-full bg-gray-200 dark:bg-gray-800">
                                    <div class="absolute left-0 top-0 h-full rounded-full bg-brand-500" style="width: @progressPercent.ToString("F0")%;"></div>
                                </div>

                                <div class="mb-4 grid grid-cols-2 gap-2 text-xs">
                                    @foreach (var milestone in GetMilestones(progressPercent))
                                    {
                                        <div class="rounded-lg px-2.5 py-2 @(milestone.IsUnlocked ? "bg-success-50 text-success-700 dark:bg-success-500/15 dark:text-success-400" : "bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-400")">
                                            <p class="font-semibold">@milestone.Label</p>
                                            <p>@milestone.Reward</p>
                                        </div>
                                    }
                                </div>

                                <div class="mt-auto flex items-end gap-2">
                                    <div class="flex-1">
                                        <label class="mb-1.5 block text-xs font-medium text-gray-500 dark:text-gray-400">Add contribution</label>
                                        <input type="number" min="0" step="0.01" value="@GetContributionInput(goal)"
                                               @oninput="e => SetContributionInput(goal.Id, e.Value?.ToString())"
                                               class="h-10 w-full rounded-lg border border-gray-300 bg-transparent px-3 py-2 text-sm text-gray-800 shadow-theme-xs focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:focus:border-brand-800" />
                                    </div>
                                    <button @onclick="() => AddContributionAsync(goal.Id)"
                                            class="inline-flex h-10 items-center justify-center rounded-lg bg-brand-500 px-4 text-sm font-medium text-white hover:bg-brand-600">Add</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        </div>
    </div>
</div>

@code {
    private GameState _state = new();

    private AppSettings _settings = new();
    private decimal _budgetSpent;

    private decimal MonthlyBudgetLimit => _settings.MonthlyIncome;

    private decimal MonthlyBudgetSpent => _budgetSpent;

    private readonly List<Transaction> _transactions = [];
    private readonly List<Transaction> _recentTransactions = [];
    private readonly List<DailyData> _spendingData = [];
    private readonly List<DailyData> _moneyTrendData = [];
    private readonly List<SummaryData> _summaryData = [];
    private readonly List<ForecastData> _forecastData = [];
    private readonly List<Goal> _goals = [];

    private SavingsState _savingsState = new();
    private decimal _savingsThisMonth;
    private decimal _savingsFallbackThisMonth;

    private decimal _projectedBalanceIn30Days;
    private decimal _projectedIncomeIn30Days;
    private decimal _projectedExpenseIn30Days;
    private decimal _lifetimeIncome;
    private decimal _lifetimeExpense;
    private decimal _balanceBeforeTrendStart;

    private decimal _monthlyTotal;
    private decimal _preAllocated;
    private decimal _nonBucketSpent;
    private decimal _remaining;

    private readonly Dictionary<int, decimal> _goalContributionInputs = new();

    private string _goalName = "";
    private decimal _goalTargetAmount;
    private decimal _goalCurrentAmount;
    private DateTime? _goalTargetDateUtc;
    private string _goalFormError = "";

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetAsync();
        await TransactionService.ApplyAutoDeductionsForBudgetPeriodAsync(_settings.MonthStartDay, DateTime.UtcNow);
        _budgetSpent = await TransactionService.GetExpenseTotalForBudgetPeriodAsync(_settings.MonthStartDay, DateTime.UtcNow);

        await GameLoop.ProcessDailyCheckInAsync();
        _state = await GameLoop.GetCurrentStateAsync();

        var now = DateTime.UtcNow;
        var transactions = await TransactionService.GetFromDateAsync(now.AddDays(-120));
        var recentTransactions = await TransactionService.GetRecentAsync(8);
        var totals = await TransactionService.GetLifetimeTotalsAsync();
        _lifetimeIncome = totals.TotalIncome;
        _lifetimeExpense = totals.TotalExpense;
        _balanceBeforeTrendStart = await TransactionService.GetNetBalanceBeforeAsync(now.AddDays(-30).Date);

        _transactions.Clear();
        _transactions.AddRange(transactions);
        _recentTransactions.Clear();
        _recentTransactions.AddRange(recentTransactions);

        var goals = await GoalService.GetAllAsync();
        _goals.Clear();
        _goals.AddRange(goals);

        _savingsState = await SavingsService.GetStateAsync();
        _savingsFallbackThisMonth = await SavingsService.GetFallbackUsedThisMonthAsync();
        var currentMonth = DateTime.UtcNow.ToString("yyyy-MM");
        var monthlySummaries = await SavingsService.GetMonthlySummariesAsync();
        _savingsThisMonth = monthlySummaries.FirstOrDefault(x => x.Month == currentMonth)?.Total ?? 0m;

        var buckets = await BucketService.GetAllAsync();
        var bucketSpentAmounts = await BucketService.GetSpentAmountsForPeriodAsync(_settings.MonthStartDay, DateTime.UtcNow);

        decimal bucketCommitted = 0;
        foreach (var bucket in buckets)
        {
            var spent = bucketSpentAmounts.TryGetValue(bucket.Id, out var s) ? s : 0m;
            bucketCommitted += Math.Max(bucket.AllocatedAmount, spent);
        }

        var bucketSpentTotal = bucketSpentAmounts.Values.Sum();
        _nonBucketSpent = Math.Max(0, _budgetSpent - bucketSpentTotal);

        var subscriptions = await SubscriptionService.GetAllAsync();
        var today = DateTime.UtcNow.Day;
        var subscriptionAllocated = subscriptions
            .Where(s => s.Status == SubscriptionStatus.Active && (!s.DebitOrderDay.HasValue || s.DebitOrderDay.Value >= today))
            .Sum(s => s.Cost);

        _preAllocated = bucketCommitted + subscriptionAllocated;

        PrepareChartData();
    }

    private void PrepareChartData()
    {
        _spendingData.Clear();
        _moneyTrendData.Clear();
        _summaryData.Clear();
        _forecastData.Clear();

        var now = DateTime.UtcNow;

        var actualIncomeThisMonth = _transactions
            .Where(t => t.Type == TransactionType.Income && t.OccurredAtUtc.ToString("yyyy-MM") == now.ToString("yyyy-MM"))
            .Sum(t => t.Amount);
        _monthlyTotal = Math.Max(_settings.MonthlyIncome, actualIncomeThisMonth);
        _remaining = _monthlyTotal - _preAllocated - _nonBucketSpent;

        if (_transactions.Count == 0)
        {
            _projectedIncomeIn30Days = 0;
            _projectedExpenseIn30Days = 0;
            _projectedBalanceIn30Days = 0;
            return;
        }

        var thirtyDaysAgo = now.AddDays(-30);

        _spendingData.AddRange(_transactions
            .Where(t => t.Type == TransactionType.Expense && t.OccurredAtUtc >= thirtyDaysAgo)
            .GroupBy(t => t.OccurredAtUtc.Date)
            .Select(g => new DailyData(g.Key, g.Sum(t => t.Amount)))
            .OrderBy(x => x.Date));

        decimal runningBalance = _balanceBeforeTrendStart;

        for (var i = 30; i >= 0; i--)
        {
            var date = now.AddDays(-i).Date;
            var dailyChange = _transactions
                .Where(t => t.OccurredAtUtc.Date == date)
                .Sum(t => t.Type == TransactionType.Income ? t.Amount : -t.Amount);

            runningBalance += dailyChange;
            _moneyTrendData.Add(new DailyData(date, runningBalance));
        }

        var totalIncome = _lifetimeIncome;
        var totalExpense = _lifetimeExpense;
        var totalSavings = totalIncome - totalExpense;

        _summaryData.Add(new SummaryData("Income", totalIncome));
        _summaryData.Add(new SummaryData("Spending", totalExpense));
        _summaryData.Add(new SummaryData("Savings", totalSavings));

        BuildForecast(now.Date, totalSavings);
    }

    private void BuildForecast(DateTime today, decimal currentBalance)
    {
        var periodStart = today.AddDays(-90);
        var recent = _transactions.Where(t => t.OccurredAtUtc.Date >= periodStart && t.OccurredAtUtc.Date <= today).ToList();
        if (recent.Count == 0)
        {
            _projectedIncomeIn30Days = 0;
            _projectedExpenseIn30Days = 0;
            _projectedBalanceIn30Days = currentBalance;
            return;
        }

        var totalIncomeLast90Days = recent.Where(t => t.Type == TransactionType.Income).Sum(t => t.Amount);
        var totalExpenseLast90Days = recent.Where(t => t.Type == TransactionType.Expense).Sum(t => t.Amount);

        var averageDailyIncome = totalIncomeLast90Days / 90m;
        var averageDailyExpense = totalExpenseLast90Days / 90m;
        var averageDailyNet = averageDailyIncome - averageDailyExpense;

        var projection = currentBalance;
        var projectedIncome = 0m;
        var projectedExpense = 0m;

        for (var day = 1; day <= 30; day++)
        {
            projectedIncome += averageDailyIncome;
            projectedExpense += averageDailyExpense;
            projection += averageDailyNet;
            _forecastData.Add(new ForecastData(today.AddDays(day), projectedIncome, projectedExpense, projection));
        }

        _projectedIncomeIn30Days = projectedIncome;
        _projectedExpenseIn30Days = projectedExpense;
        _projectedBalanceIn30Days = projection;
    }

    private async Task CreateGoalAsync()
    {
        _goalFormError = "";

        if (string.IsNullOrWhiteSpace(_goalName))
        {
            _goalFormError = "Goal name is required.";
            return;
        }

        if (_goalTargetAmount <= 0)
        {
            _goalFormError = "Target amount must be greater than zero.";
            return;
        }

        if (_goalCurrentAmount < 0)
        {
            _goalFormError = "Current amount cannot be negative.";
            return;
        }

        var current = Math.Min(_goalCurrentAmount, _goalTargetAmount);

        await GoalService.CreateAsync(new Goal
        {
            Name = _goalName.Trim(),
            TargetAmount = _goalTargetAmount,
            CurrentAmount = current,
            TargetDateUtc = _goalTargetDateUtc,
            Status = current >= _goalTargetAmount ? GoalStatus.Completed : GoalStatus.Active
        });

        _goalName = "";
        _goalTargetAmount = 0;
        _goalCurrentAmount = 0;
        _goalTargetDateUtc = null;

        await ReloadGoalsAsync();
    }

    private async Task AddContributionAsync(int goalId)
    {
        if (!_goalContributionInputs.TryGetValue(goalId, out var amount) || amount <= 0)
        {
            return;
        }

        var goal = _goals.FirstOrDefault(x => x.Id == goalId);
        if (goal is null)
        {
            return;
        }

        goal.CurrentAmount = Math.Min(goal.TargetAmount, goal.CurrentAmount + amount);
        goal.Status = goal.CurrentAmount >= goal.TargetAmount ? GoalStatus.Completed : GoalStatus.Active;

        await GoalService.UpdateAsync(goal);
        await ReloadGoalsAsync();
    }

    private async Task ReloadGoalsAsync()
    {
        var goals = await GoalService.GetAllAsync();
        _goals.Clear();
        _goals.AddRange(goals);
    }

    private decimal GetContributionInput(Goal goal)
    {
        if (_goalContributionInputs.TryGetValue(goal.Id, out var amount))
        {
            return amount;
        }

        _goalContributionInputs[goal.Id] = 0m;
        return 0m;
    }

    private void SetContributionInput(int goalId, string? value)
    {
        if (decimal.TryParse(value, out var parsed))
        {
            _goalContributionInputs[goalId] = parsed;
        }
    }

    private static IEnumerable<MilestoneData> GetMilestones(decimal progressPercent)
    {
        yield return new MilestoneData("25%", "Starter Badge", progressPercent >= 25);
        yield return new MilestoneData("50%", "Momentum Badge", progressPercent >= 50);
        yield return new MilestoneData("75%", "Champion Badge", progressPercent >= 75);
        yield return new MilestoneData("100%", "Goal Unlocked", progressPercent >= 100);
    }

    private string FormatC(decimal amount) => MoneyFormatter.Format(_settings.Currency, amount);
    private string FormatC0(decimal amount) => MoneyFormatter.Format(_settings.Currency, amount, 0);

    public sealed record DailyData(DateTime Date, decimal Amount);
    public sealed record SummaryData(string Label, decimal Amount);
    public sealed record ForecastData(DateTime Date, decimal ProjectedIncomeCumulative, decimal ProjectedExpenseCumulative, decimal ProjectedNetBalance);
    public sealed record MilestoneData(string Label, string Reward, bool IsUnlocked);
}
