@page "/debt-simulator"
@rendermode InteractiveServer
@using CoinStack.Data.Entities
@using CoinStack.Services
@inject IDebtService DebtService
@inject ISettingsService SettingsService
@inject IMoneyFormatter MoneyFormatter

<PageTitle>Debt Payoff Simulator</PageTitle>

<div class="space-y-6">
    <div class="mb-2">
        <h2 class="text-xl font-semibold text-gray-800 dark:text-white/90">Debt Payoff Simulator</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Pick a debt and adjust the monthly payment to instantly see how it changes your payoff date and total interest.</p>
    </div>

    @if (_loading)
    {
        <div class="flex min-h-[300px] items-center justify-center rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
            <p class="text-sm text-gray-500 dark:text-gray-400">Loading debts...</p>
        </div>
    }
    else if (_debts.Count == 0)
    {
        <div class="flex min-h-[300px] flex-col items-center justify-center gap-4 rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
            <svg class="text-gray-300 dark:text-gray-600" width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4.5 9.75C4.5 9.33579 4.83579 9 5.25 9H18.75C19.1642 9 19.5 9.33579 19.5 9.75V19.5C19.5 20.3284 18.8284 21 18 21H6C5.17157 21 4.5 20.3284 4.5 19.5V9.75Z" fill="currentColor" />
                <path d="M12 2.25C9.51472 2.25 7.5 4.26472 7.5 6.75V7.5H9V6.75C9 5.09315 10.3431 3.75 12 3.75C13.6569 3.75 15 5.09315 15 6.75V7.5H16.5V6.75C16.5 4.26472 14.4853 2.25 12 2.25Z" fill="currentColor" />
            </svg>
            <div class="text-center">
                <p class="font-medium text-gray-700 dark:text-gray-300">No debts found</p>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Add a debt on the Debt Calculator page first.</p>
            </div>
            <a href="/debt" class="inline-flex items-center justify-center rounded-full bg-brand-500 px-5 py-2.5 mb-4 text-sm font-medium text-white hover:bg-brand-600">
                Go to Debt Calculator
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-6 xl:grid-cols-12">

            <!-- LEFT: Inputs -->
            <div class="space-y-4 xl:col-span-5">

                <!-- Debt selector -->
                <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
                    <h3 class="mb-4 text-base font-semibold text-gray-800 dark:text-white/90">Select Debt</h3>

                    <select value="@_selectedDebtIdStr"
                            @onchange="OnDebtChange"
                            class="h-11 w-full rounded-md border border-gray-300 bg-transparent px-4 py-2 text-sm text-gray-900 focus:border-brand-600 focus:outline-none dark:border-gray-600 dark:bg-gray-700 dark:text-white">
                        @foreach (var debt in _debts)
                        {
                            <option value="@debt.Id">@debt.Name@(string.IsNullOrWhiteSpace(debt.Provider) ? "" : $" — {debt.Provider}")</option>
                        }
                    </select>

                    @if (_selectedDebt is not null)
                    {
                        <div class="mt-4 grid grid-cols-2 gap-3">
                            <div class="rounded-xl bg-gray-50 p-3 dark:bg-gray-800/70">
                                <p class="text-xs text-gray-500 dark:text-gray-400">Current Balance</p>
                                <p class="font-semibold text-gray-800 dark:text-white/90">@FormatC(_selectedDebt.CurrentBalance)</p>
                            </div>
                            <div class="rounded-xl bg-gray-50 p-3 dark:bg-gray-800/70">
                                <p class="text-xs text-gray-500 dark:text-gray-400">Interest Rate</p>
                                <p class="font-semibold text-gray-800 dark:text-white/90">@_selectedDebt.InterestRatePercent.ToString("0.##")% APR</p>
                            </div>
                            <div class="rounded-xl bg-gray-50 p-3 dark:bg-gray-800/70">
                                <p class="text-xs text-gray-500 dark:text-gray-400">Current Payment</p>
                                <p class="font-semibold text-gray-800 dark:text-white/90">@FormatC(_selectedDebt.MonthlyPaymentAmount) / mo</p>
                            </div>
                            <div class="rounded-xl bg-gray-50 p-3 dark:bg-gray-800/70">
                                <p class="text-xs text-gray-500 dark:text-gray-400">Monthly Interest</p>
                                <p class="font-semibold text-error-600 dark:text-error-400">@FormatC(GetMonthlyInterest(_selectedDebt))</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Payment simulator -->
                @if (_selectedDebt is not null)
                {
                    <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
                        <h3 class="mb-1 text-base font-semibold text-gray-800 dark:text-white/90">Simulated Monthly Payment</h3>
                        <p class="mb-5 text-xs text-gray-500 dark:text-gray-400">Drag the slider or type an amount to instantly recalculate.</p>

                        <div class="mb-5 flex items-baseline gap-2">
                            <span class="text-3xl font-bold text-brand-600 dark:text-brand-400">@FormatC(_simPayment, 0)</span>
                            <span class="text-sm text-gray-500 dark:text-gray-400">/ month</span>
                        </div>

                        <!-- Range slider -->
                        <input type="range"
                               min="@((double)_sliderMin)"
                               max="@((double)_sliderMax)"
                               step="@((double)_sliderStep)"
                               value="@((double)_simPayment)"
                               @oninput="OnSliderInput"
                               class="w-full cursor-pointer"
                               style="accent-color: var(--color-brand-500)" />

                        <div class="mt-1 mb-5 flex justify-between text-xs text-gray-400">
                            <span>@FormatC(_sliderMin, 0)</span>
                            <span>@FormatC(_sliderMax, 0)</span>
                        </div>

                        <!-- Exact amount input -->
                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Or enter exact amount</label>
                        <div class="flex items-center overflow-hidden rounded-md border border-gray-300 bg-white focus-within:border-brand-500 focus-within:ring-1 focus-within:ring-brand-500 dark:border-gray-600 dark:bg-gray-700">
                            <div class="flex h-11 w-11 shrink-0 items-center justify-center border-r border-gray-300 bg-gray-100 text-sm text-gray-500 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-400">
                                @_currencySymbol
                            </div>
                            <input type="number"
                                   min="1"
                                   step="10"
                                   value="@_simPayment.ToString("F0")"
                                   @oninput="OnNumberInput"
                                   class="block w-full border-0 bg-transparent px-4 py-3 text-sm text-gray-900 focus:ring-0 dark:text-white" />
                        </div>

                        <!-- Quick presets -->
                        <div class="mt-3 flex flex-wrap gap-2">
                            @foreach (var (label, amount) in GetPresets())
                            {
                                <button type="button"
                                        @onclick="() => SetPreset(amount)"
                                        class="rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs font-medium text-gray-600 transition-colors hover:border-brand-300 hover:bg-brand-50 hover:text-brand-600 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:border-brand-500 dark:hover:text-brand-400">
                                    @label
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- RIGHT: Results -->
            <div class="space-y-4 xl:col-span-7">
                @if (_selectedDebt is not null && _currentResult is not null && _simResult is not null)
                {
                    <!-- Payment too low warning -->
                    @if (_simResult.IsUnpayable)
                    {
                        <div class="rounded-2xl border border-error-200 bg-error-50 p-5 dark:border-error-500/40 dark:bg-error-500/10">
                            <p class="font-semibold text-error-700 dark:text-error-400">Payment too low</p>
                            <p class="mt-1 text-sm text-error-600 dark:text-error-300">
                                @FormatC(_simPayment) doesn't cover the @FormatC(GetMonthlyInterest(_selectedDebt)) monthly interest — the balance would keep growing.
                                Increase to at least @FormatC(_sliderMin) to make progress.
                            </p>
                        </div>
                    }

                    <!-- Comparison cards -->
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">

                        <!-- Current plan -->
                        <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03]">
                            <p class="mb-1 text-xs font-medium uppercase tracking-wide text-gray-400 dark:text-gray-500">Current Plan</p>
                            <p class="mb-4 text-xl font-bold text-gray-800 dark:text-white/90">
                                @FormatC(_selectedDebt.MonthlyPaymentAmount)
                                <span class="text-sm font-normal text-gray-400">/ mo</span>
                            </p>
                            <div class="space-y-2.5">
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-500 dark:text-gray-400">Payoff time</span>
                                    <span class="font-medium text-gray-800 dark:text-white/90">@FormatTerm(_currentResult)</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-500 dark:text-gray-400">Payoff date</span>
                                    <span class="font-medium text-gray-800 dark:text-white/90">@(_currentResult.PayoffDate?.ToString("MMM yyyy") ?? "—")</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-500 dark:text-gray-400">Total paid</span>
                                        <span class="font-medium text-gray-800 dark:text-white/90">@FormatC(_currentResult.TotalPaid)</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-500 dark:text-gray-400">Total interest</span>
                                        <span class="font-medium text-error-600 dark:text-error-400">@FormatC(_currentResult.TotalInterest)</span>
                                </div>
                            </div>
                        </div>

                        <!-- Simulated plan -->
                        <div class="rounded-2xl border p-5
                            @(_simPayment > _selectedDebt.MonthlyPaymentAmount
                                ? "border-brand-200 bg-brand-50 dark:border-brand-500/30 dark:bg-brand-500/10"
                                : _simPayment < _selectedDebt.MonthlyPaymentAmount
                                    ? "border-warning-200 bg-warning-50 dark:border-warning-500/30 dark:bg-warning-500/10"
                                    : "border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]")">
                            <p class="mb-1 text-xs font-medium uppercase tracking-wide
                                @(_simPayment > _selectedDebt.MonthlyPaymentAmount
                                    ? "text-brand-500 dark:text-brand-400"
                                    : _simPayment < _selectedDebt.MonthlyPaymentAmount
                                        ? "text-warning-600 dark:text-warning-400"
                                        : "text-gray-400 dark:text-gray-500")">
                                Your Simulation
                            </p>
                            <p class="mb-4 text-xl font-bold text-gray-800 dark:text-white/90">
                                @FormatC(_simPayment)
                                <span class="text-sm font-normal text-gray-400">/ mo</span>
                            </p>
                            @if (!_simResult.IsUnpayable)
                            {
                                <div class="space-y-2.5">
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500 dark:text-gray-400">Payoff time</span>
                                        <span class="font-medium text-gray-800 dark:text-white/90">@FormatTerm(_simResult)</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500 dark:text-gray-400">Payoff date</span>
                                        <span class="font-medium text-gray-800 dark:text-white/90">@(_simResult.PayoffDate?.ToString("MMM yyyy") ?? "—")</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500 dark:text-gray-400">Total paid</span>
                                        <span class="font-medium text-gray-800 dark:text-white/90">@FormatC(_simResult.TotalPaid)</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-500 dark:text-gray-400">Total interest</span>
                                        <span class="font-medium text-error-600 dark:text-error-400">@FormatC(_simResult.TotalInterest)</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="text-sm text-error-600 dark:text-error-400">Debt would never be paid off.</p>
                            }
                        </div>
                    </div>

                    <!-- Savings banner -->
                    @if (!_simResult.IsUnpayable && _simPayment > _selectedDebt.MonthlyPaymentAmount)
                    {
                        var monthsSaved = (_currentResult.Months ?? 0) - (_simResult.Months ?? 0);
                        var interestSaved = _currentResult.TotalInterest - _simResult.TotalInterest;
                        var totalSaved = _currentResult.TotalPaid - _simResult.TotalPaid;

                        <div class="rounded-2xl border border-success-200 bg-success-50 p-5 dark:border-success-500/30 dark:bg-success-500/10">
                            <p class="mb-4 text-sm font-semibold text-success-700 dark:text-success-400">
                                By paying @FormatC(_simPayment) / month instead of @FormatC(_selectedDebt.MonthlyPaymentAmount), you save:
                            </p>
                            <div class="grid grid-cols-3 divide-x divide-success-200 dark:divide-success-500/30 text-center">
                                <div class="px-3">
                                    <p class="text-xl font-bold text-success-700 dark:text-success-400">@FormatMonthDelta(monthsSaved)</p>
                                    <p class="mt-0.5 text-xs text-success-600 dark:text-success-500">sooner</p>
                                </div>
                                <div class="px-3">
                                    <p class="text-xl font-bold text-success-700 dark:text-success-400">@FormatC(interestSaved, 0)</p>
                                    <p class="mt-0.5 text-xs text-success-600 dark:text-success-500">less interest</p>
                                </div>
                                <div class="px-3">
                                    <p class="text-xl font-bold text-success-700 dark:text-success-400">@FormatC(totalSaved, 0)</p>
                                    <p class="mt-0.5 text-xs text-success-600 dark:text-success-500">total saved</p>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Lower payment warning -->
                    @if (!_simResult.IsUnpayable && _simPayment < _selectedDebt.MonthlyPaymentAmount)
                    {
                        var monthsExtra = (_simResult.Months ?? 0) - (_currentResult.Months ?? 0);
                        var interestExtra = _simResult.TotalInterest - _currentResult.TotalInterest;

                        <div class="rounded-2xl border border-warning-200 bg-warning-50 p-5 dark:border-warning-500/30 dark:bg-warning-500/10">
                            <p class="font-semibold text-warning-700 dark:text-warning-400">Lower payment impact</p>
                            <p class="mt-1 text-sm text-warning-600 dark:text-warning-300">
                                Dropping to @FormatC(_simPayment) / month adds
                                <strong>@FormatMonthDelta(monthsExtra)</strong> to the timeline and costs
                                <strong>@FormatC(interestExtra)</strong> more in interest.
                            </p>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Amortization schedule -->
        @if (_selectedDebt is not null && _simResult is not null && !_simResult.IsUnpayable && _simResult.Schedule.Count > 0)
        {
            <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
                <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 dark:border-gray-800">
                    <div>
                        <h3 class="text-base font-semibold text-gray-800 dark:text-white/90">Amortization Schedule</h3>
                        <p class="text-xs text-gray-500 dark:text-gray-400">
                            @_simResult.Schedule.Count payment@(_simResult.Schedule.Count != 1 ? "s" : "") at @FormatC(_simPayment) / month
                        </p>
                    </div>
                    @if (_simResult.Schedule.Count > 12)
                    {
                        <button type="button"
                                @onclick="() => _showFullSchedule = !_showFullSchedule"
                                class="text-sm font-medium text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300">
                            @(_showFullSchedule ? "Show less" : $"Show all {_simResult.Schedule.Count} rows")
                        </button>
                    }
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400">#</th>
                                <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400">Date</th>
                                <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400">Payment</th>
                                <th class="px-5 py-3 text-right text-xs font-medium text-success-600 dark:text-success-400">Principal</th>
                                <th class="px-5 py-3 text-right text-xs font-medium text-error-500 dark:text-error-400">Interest</th>
                                <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400">Balance</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                            @foreach (var row in _showFullSchedule ? _simResult.Schedule : _simResult.Schedule.Take(12))
                            {
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50">
                                    <td class="px-5 py-3 text-xs text-gray-400 dark:text-gray-500">@row.Month</td>
                                    <td class="px-5 py-3 text-gray-700 dark:text-gray-300">@row.Date.ToString("MMM yyyy")</td>
                                    <td class="px-5 py-3 text-right font-medium text-gray-800 dark:text-white/90">@FormatC(row.Payment)</td>
                                    <td class="px-5 py-3 text-right font-medium text-success-600 dark:text-success-400">@FormatC(row.Principal)</td>
                                    <td class="px-5 py-3 text-right text-error-500 dark:text-error-400">@FormatC(row.Interest)</td>
                                    <td class="px-5 py-3 text-right text-gray-600 dark:text-gray-300">@FormatC(row.Balance)</td>
                                </tr>
                            }
                        </tbody>
                        @if (_simResult.Schedule.Count > 0)
                        {
                            <tfoot>
                                <tr class="border-t border-gray-200 bg-gray-50 dark:border-gray-700 dark:bg-gray-800/50">
                                    <td colspan="2" class="px-5 py-3 text-xs font-semibold text-gray-600 dark:text-gray-300">Total</td>
                                    <td class="px-5 py-3 text-right text-xs font-semibold text-gray-800 dark:text-white/90">@FormatC(_simResult.TotalPaid)</td>
                                    <td class="px-5 py-3 text-right text-xs font-semibold text-success-600 dark:text-success-400">@FormatC(_simResult.TotalPaid - _simResult.TotalInterest)</td>
                                    <td class="px-5 py-3 text-right text-xs font-semibold text-error-500 dark:text-error-400">@FormatC(_simResult.TotalInterest)</td>
                                    <td class="px-5 py-3 text-right text-xs font-semibold text-gray-800 dark:text-white/90">—</td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>

                @if (!_showFullSchedule && _simResult.Schedule.Count > 12)
                {
                    <div class="border-t border-gray-100 px-6 py-3 text-center dark:border-gray-800">
                        <button type="button"
                                @onclick="() => _showFullSchedule = true"
                                class="text-sm font-medium text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300">
                            Show @(_simResult.Schedule.Count - 12) more rows
                        </button>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    // ── State ───────────────────────────────────────────────────────────────
    private List<DebtAccount> _debts = [];
    private bool _loading = true;
    private string _selectedDebtIdStr = "";
    private DebtAccount? _selectedDebt;
    private decimal _simPayment;
    private decimal _sliderMin;
    private decimal _sliderMax;
    private decimal _sliderStep = 10m;
    private AppSettings _settings = new();
    private string _currencySymbol = "$";
    private bool _showFullSchedule;
    private SimResult? _currentResult;
    private SimResult? _simResult;

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetAsync();
        _currencySymbol = MoneyFormatter.Symbol(_settings.Currency);

        _debts = (await DebtService.GetAllAsync())
            .Where(d => d.CurrentBalance > 0)
            .OrderBy(d => d.Name)
            .ToList();

        _loading = false;

        if (_debts.Count > 0)
        {
            _selectedDebtIdStr = _debts[0].Id.ToString();
            LoadDebt(_debts[0]);
        }
    }

    // ── Event handlers ────────────────────────────────────────────────────
    private void OnDebtChange(ChangeEventArgs e)
    {
        _selectedDebtIdStr = e.Value?.ToString() ?? "";
        if (int.TryParse(_selectedDebtIdStr, out var id))
        {
            var debt = _debts.FirstOrDefault(d => d.Id == id);
            if (debt is not null)
                LoadDebt(debt);
        }
    }

    private void OnSliderInput(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
        {
            _simPayment = Math.Round(Math.Max(_sliderMin, val), 2);
            _showFullSchedule = false;
            RunSimulation();
        }
    }

    private void OnNumberInput(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val) && val > 0)
        {
            _simPayment = Math.Round(val, 2);
            _showFullSchedule = false;
            RunSimulation();
        }
    }

    private void SetPreset(decimal amount)
    {
        _simPayment = amount;
        _showFullSchedule = false;
        RunSimulation();
    }

    // ── Debt loading ─────────────────────────────────────────────────────
    private void LoadDebt(DebtAccount debt)
    {
        _selectedDebt = debt;
        _showFullSchedule = false;

        var monthlyInterest = GetMonthlyInterest(debt);
        _sliderMin = Math.Max(1m, Math.Ceiling(monthlyInterest) + 1m);
        _sliderMax = Math.Max(debt.MonthlyPaymentAmount * 4m, debt.MonthlyPaymentAmount + 1000m);
        _sliderStep = _sliderMax > 5000m ? 50m : _sliderMax > 1000m ? 10m : 5m;

        _simPayment = Math.Clamp(debt.MonthlyPaymentAmount, _sliderMin, _sliderMax);
        RunSimulation();
    }

    // ── Simulation engine ────────────────────────────────────────────────
    private void RunSimulation()
    {
        if (_selectedDebt is null) return;
        _currentResult = Simulate(_selectedDebt.CurrentBalance, _selectedDebt.InterestRatePercent, _selectedDebt.MonthlyPaymentAmount);
        _simResult = Simulate(_selectedDebt.CurrentBalance, _selectedDebt.InterestRatePercent, _simPayment);
    }

    private static SimResult Simulate(decimal balance, decimal annualRatePercent, decimal monthlyPayment)
    {
        if (balance <= 0)
            return new SimResult(0, 0m, 0m, DateTime.Today, []);

        var monthlyRate = annualRatePercent / 100m / 12m;
        var minViable = monthlyRate > 0 ? balance * monthlyRate : 0m;

        if (monthlyPayment <= minViable && monthlyRate > 0)
            return new SimResult(null, 0m, 0m, null, []) with { IsUnpayable = true };

        var rows = new List<SimRow>();
        var current = balance;
        var date = DateTime.Today;
        var totalInterest = 0m;

        while (current > 0.005m && rows.Count < 600)
        {
            var interest = monthlyRate > 0 ? decimal.Round(current * monthlyRate, 2) : 0m;
            var payment = Math.Min(monthlyPayment, current + interest);
            var principal = decimal.Round(payment - interest, 2);

            if (principal <= 0) break;

            current = decimal.Round(Math.Max(0m, current - principal), 2);
            date = date.AddMonths(1);
            totalInterest = decimal.Round(totalInterest + interest, 2);
            rows.Add(new SimRow(rows.Count + 1, date, decimal.Round(payment, 2), principal, interest, current));
        }

        var hitCap = current > 0.005m;
        return hitCap
            ? new SimResult(null, decimal.Round(rows.Sum(r => r.Payment), 2), totalInterest, null, rows) with { IsUnpayable = true }
            : new SimResult(rows.Count, decimal.Round(rows.Sum(r => r.Payment), 2), totalInterest, rows.LastOrDefault()?.Date, rows);
    }

    // ── Presets ──────────────────────────────────────────────────────────
    private IEnumerable<(string Label, decimal Amount)> GetPresets()
    {
        if (_selectedDebt is null) yield break;
        var cur = _selectedDebt.MonthlyPaymentAmount;
        if (cur <= 0) yield break;

        var extra25 = Math.Round(cur * 0.25m, 0);
        var extra50 = Math.Round(cur * 0.50m, 0);

        yield return ($"+{FormatC(extra25, 0)}/mo", Math.Round(cur + extra25, 0));
        yield return ($"+{FormatC(extra50, 0)}/mo", Math.Round(cur + extra50, 0));
        yield return ("2× payment", Math.Round(cur * 2m, 0));
    }

    // ── Helpers ──────────────────────────────────────────────────────────
    private static decimal GetMonthlyInterest(DebtAccount debt)
        => debt.InterestRatePercent > 0
            ? decimal.Round(debt.CurrentBalance * (debt.InterestRatePercent / 100m / 12m), 2)
            : 0m;

    private static string FormatTerm(SimResult result)
    {
        if (result.IsUnpayable) return "Never";
        var months = result.Months ?? 0;
        if (months == 0) return "Already paid off";
        var y = months / 12;
        var m = months % 12;
        return (y, m) switch
        {
            (0, _) => $"{months} month{(months != 1 ? "s" : "")}",
            (_, 0) => $"{y} year{(y != 1 ? "s" : "")} ({months} mo)",
            _ => $"{y}y {m}mo ({months} months)"
        };
    }

    private static string FormatMonthDelta(int months)
    {
        if (months <= 0) return "0 months";
        var y = months / 12;
        var m = months % 12;
        return (y, m) switch
        {
            (0, _) => $"{months} month{(months != 1 ? "s" : "")}",
            (_, 0) => $"{y} year{(y != 1 ? "s" : "")}",
            _ => $"{y}y {m}mo"
        };
    }

    private string FormatC(decimal amount, int decimals = 2) => MoneyFormatter.Format(_settings.Currency, amount, decimals);

    // ── Models ───────────────────────────────────────────────────────────
    private sealed record SimResult(
        int? Months,
        decimal TotalPaid,
        decimal TotalInterest,
        DateTime? PayoffDate,
        List<SimRow> Schedule)
    {
        public bool IsUnpayable { get; init; }
    }

    private sealed record SimRow(
        int Month,
        DateTime Date,
        decimal Payment,
        decimal Principal,
        decimal Interest,
        decimal Balance);
}
