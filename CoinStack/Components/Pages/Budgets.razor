@page "/budgets"
@rendermode InteractiveServer
@using CoinStack.Data.Entities
@inject CoinStack.Services.IBucketService BucketService
@inject CoinStack.Services.ICategoryService CategoryService
@inject CoinStack.Services.ITransactionService TransactionService
@inject CoinStack.Services.ISettingsService SettingsService

<PageTitle>Buckets</PageTitle>

<div>
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-semibold text-gray-800 dark:text-white/90">Spending Buckets</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage your monthly spending envelopes</p>
        </div>

        <button
            class="flex h-11 w-11 items-center justify-center rounded-full bg-brand-50 text-brand-600 transition-colors hover:bg-brand-100 dark:bg-brand-500/15 dark:text-brand-400 dark:hover:bg-brand-500/25"
            @onclick="OpenCreateModal" title="Add Bucket">
            <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none"
                 xmlns="http://www.w3.org/2000/svg">
                <path
                d="M12 4C11.5858 4 11.25 4.33579 11.25 4.75V11.25H4.75C4.33579 11.25 4 11.5858 4 12C4 12.4142 4.33579 12.75 4.75 12.75H11.25V19.25C11.25 19.6642 11.5858 20 12 20C12.4142 20 12.75 19.6642 12.75 19.25V12.75H19.25C19.6642 12.75 20 12.4142 20 12C20 11.5858 19.6642 11.25 19.25 11.25H12.75V4.75C12.75 4.33579 12.4142 4 12 4Z"
                fill="currentColor" />
            </svg>
        </button>
    </div>

    @if (!_isLoading && _buckets.Count > 0)
    {
        <div
            class="mb-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-white/[0.03]">
            <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
                <div class="text-center sm:text-left">
                    <h3 class="text-lg font-bold text-gray-800 dark:text-white/90">Monthly Budget Remaining</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">@_budgetSpent.ToString("C") spent of
                        @_budgetLimit.ToString("C")</p>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <span
                                class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300">
                                <span class="inline-block h-2.5 w-2.5 rounded-full bg-gray-400"></span>
                                Planned: @_totalPlanned.ToString("C")
                            </span>
                            <span
                                class="inline-flex items-center gap-1.5 rounded-full bg-error-50 px-3 py-1 text-xs font-medium text-error-600 dark:bg-error-500/15 dark:text-error-400">
                                <span class="inline-block h-2.5 w-2.5 rounded-full bg-error-500"></span>
                                Actually Spent: @_budgetSpent.ToString("C")
                            </span>
                            <span
                                class="inline-flex items-center gap-1.5 rounded-full bg-success-50 px-3 py-1 text-xs font-medium text-success-600 dark:bg-success-500/15 dark:text-success-400">
                                <span class="inline-block h-2.5 w-2.5 rounded-full bg-success-500"></span>
                                Available: @((_budgetLimit - _totalAllocated).ToString("C"))
                            </span>
                        </div>
                    </div>
                    <BudgetDonut BudgetLimit="@_budgetLimit" Spent="@_budgetSpent" Size="260" />
                </div>
            </div>
        }

        @if (_isLoading)
        {
            <div class="text-sm text-gray-500 dark:text-gray-400">Loading...</div>
        }
        else if (_buckets.Count == 0)
        {
            <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center dark:border-gray-800 dark:bg-white/[0.03]">
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">No buckets yet. Create your first spending bucket!</p>
                <button @onclick="OpenCreateModal"
                        class="inline-flex items-center justify-center rounded-full bg-brand-500 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                    Create First Bucket
                </button>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
                @foreach (var bucket in _buckets)
                {
                    var spent = _spentAmounts.GetValueOrDefault(bucket.Id);
                    var remaining = bucket.AllocatedAmount - spent;
                    var percentUsed = bucket.AllocatedAmount > 0 ? (double)(spent / bucket.AllocatedAmount) * 100 : 0;
                    var isOver = spent > bucket.AllocatedAmount;

                    <div
                        class="rounded-2xl border border-gray-200 bg-white p-5 transition-shadow duration-200 hover:shadow-theme-md dark:border-gray-800 dark:bg-white/[0.03]">
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center gap-3">
                                <div class="h-4 w-4 rounded-full"
                                     style="background-color: @(bucket.Category?.ColorHex ?? "#6577F3");"></div>
                                <div>
                                    <h4 class="text-base font-medium text-gray-800 dark:text-white/90">@bucket.Name</h4>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">@(bucket.Category?.Name ?? "No category")
                                    </p>
                                </div>
                            </div>
                            <div class="flex items-center gap-1">
                                <button @onclick="() => OpenEditModal(bucket)"
                                        class="text-gray-400 transition-colors hover:text-brand-500 dark:hover:text-brand-400"
                                        title="Edit bucket">
                                    <svg class="fill-current" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                         xmlns="http://www.w3.org/2000/svg">
                                        <path fill-rule="evenodd" clip-rule="evenodd"
                                              d="M15.4901 3.21967C15.783 2.92678 16.2578 2.92678 16.5507 3.21967L20.7807 7.44967C21.0736 7.74256 21.0736 8.21744 20.7807 8.51033L9.53073 19.7603C9.38998 19.9011 9.19912 19.9803 9.00007 19.9803H4.77007C4.35586 19.9803 4.02007 19.6446 4.02007 19.2303V15.0003C4.02007 14.8013 4.09929 14.6104 4.24001 14.4697L15.4901 3.21967ZM5.52007 15.3109V18.4803H8.68951L19.1894 7.98033L16.0201 4.81099L5.52007 15.3109Z"
                                              fill="currentColor" />
                                    </svg>
                                </button>
                                <button @onclick="() => DeleteBucketAsync(bucket.Id)"
                                        class="text-gray-400 transition-colors hover:text-error-500 dark:hover:text-error-400"
                                        title="Delete bucket">
                                    <svg class="fill-current" width="18" height="18" viewBox="0 0 18 18" fill="none"
                                         xmlns="http://www.w3.org/2000/svg">
                                        <path
                                        d="M15.75 4.5H2.25M7.5 8.25V12.75M10.5 8.25V12.75M14.25 4.5V14.25C14.25 15.0784 13.5784 15.75 12.75 15.75H5.25C4.42157 15.75 3.75 15.0784 3.75 14.25V4.5M6 4.5V3C6 2.17157 6.67157 1.5 7.5 1.5H10.5C11.3284 1.5 12 2.17157 12 3V4.5"
                                        stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                                        fill="none" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="flex items-end justify-between mb-1">
                                <span class="text-2xl font-bold text-gray-800 dark:text-white/90">@spent.ToString("C")</span>
                                <span class="text-sm text-gray-500 dark:text-gray-400">/
                                    @bucket.AllocatedAmount.ToString("C")</span>
                                </div>

                                <!-- Planned vs Actual Stacked Bar -->
                                <div class="mt-3 space-y-1.5">
                                    <div>
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span
                                            class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-wide">Planned</span>
                                            <span
                                            class="text-[10px] font-medium text-gray-500 dark:text-gray-400">@bucket.AllocatedAmount.ToString("C")</span>
                                        </div>
                                        <div class="h-2 rounded-full bg-gray-100 dark:bg-gray-800 overflow-hidden">
                                            @{
                                                var plannedPct = _budgetLimit > 0 ? (double)(bucket.AllocatedAmount / _budgetLimit) * 100
                                        : 0;
                                            }
                                            <div class="h-full rounded-full bg-gray-400 dark:bg-gray-500 transition-all duration-300"
                                                 style="width: @(Math.Min(100, plannedPct).ToString("F1"))%"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span
                                            class="text-[10px] uppercase tracking-wide @(isOver ? "text-error-400" : "text-error-400 dark:text-error-500")">Actual</span>
                                            <span
                                            class="text-[10px] font-medium @(isOver ? "text-error-500" : "text-gray-500 dark:text-gray-400")">@spent.ToString("C")</span>
                                        </div>
                                        <div class="h-2 rounded-full bg-gray-100 dark:bg-gray-800 overflow-hidden">
                                            @{
                                                var actualPct = bucket.AllocatedAmount > 0 ? (double)(spent / bucket.AllocatedAmount) *
                                        100 : 0;
                                            }
                                            <div class="h-full rounded-full transition-all duration-300 @(isOver ? "bg-error-500" : "bg-error-400 dark:bg-error-400")"
                                                 style="width: @(Math.Min(100, actualPct).ToString("F1"))%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex items-center justify-between">
                                <span
                                    class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium @(isOver ? "bg-error-50 text-error-600 dark:bg-error-500/15 dark:text-error-500" : "bg-success-50 text-success-600 dark:bg-success-500/15 dark:text-success-500")">
                                    @(isOver ? $"{Math.Abs(remaining):C} over" : $"{remaining:C} left")
                                </span>
                                <span class="text-xs text-gray-500 dark:text-gray-400">@percentUsed.ToString("F0")% used</span>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (_showModal)
            {
                <!-- Create/Edit Bucket Modal -->
                <div class="fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5 modal-backdrop-enter">
                    <div class="fixed inset-0 h-full w-full bg-gray-400/50 backdrop-blur-[32px]" @onclick="CloseModal"></div>
                    <div class="relative w-full max-w-[584px] rounded-3xl bg-white p-6 dark:bg-gray-900 lg:p-10 modal-panel-enter">
                        <button @onclick="CloseModal" type="button"
                                class="group absolute right-3 top-3 z-999 flex h-9.5 w-9.5 items-center justify-center rounded-full bg-gray-200 text-gray-500 transition-colors hover:bg-gray-300 hover:text-gray-500 dark:bg-gray-800 dark:hover:bg-gray-700 sm:right-6 sm:top-6 sm:h-11 sm:w-11">
                            <svg class="fill-current transition-colors group-hover:text-gray-600 dark:group-hover:text-gray-200"
                                 width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" clip-rule="evenodd"
                                      d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z"
                                      fill="" />
                            </svg>
                        </button>

                        <form @onsubmit="SaveBucketAsync" @onsubmit:preventDefault="true">
                            <h4 class="mb-6 text-lg font-medium text-gray-800 dark:text-white/90">@(_editingId.HasValue ? "Edit Bucket" : "New Bucket")</h4>

                            <div class="space-y-5">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Bucket
                                        Name</label>
                                        <input type="text" placeholder="e.g. Snacks, Going Out, Savings" @bind="_formName"
                                               class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400" />
                                    </div>

                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Monthly
                                            Allocation</label>
                                            <input type="number" step="0.01" inputmode="decimal" placeholder="0.00"
                                                   @bind-value="_formAllocated" @bind-value:event="oninput"
                                                   class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400" />
                                        </div>

                                        <div>
                                            <label
                                            class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Category</label>
                                            <select @bind="_formCategoryId"
                                                    class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-brand-400">
                                                <option value="">Select a category</option>
                                                @foreach (var category in _expenseCategories)
                                                {
                                                    <option value="@category.Id">@category.Name</option>
                                                }
                                            </select>
                                            @if (_expenseCategories.Count == 0)
                                            {
                                                <p class="mt-1.5 text-xs text-error-600 dark:text-error-400">No expense categories available.
                                                    Create one on the Categories page first.</p>
                                                }
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(_formError))
                                            {
                                                <div
                                                    class="rounded-lg border border-error-200 bg-error-50 px-3 py-2 text-sm text-error-700 dark:border-error-500/40 dark:bg-error-500/10 dark:text-error-400">
                                                    @_formError</div>
                                                }
                                            </div>

                                            <div class="mt-6 flex w-full items-center justify-end gap-3">
                                                <button @onclick="CloseModal" type="button"
                                                        class="flex w-full justify-center rounded-full border border-gray-300 bg-white px-6 py-2.5 text-sm font-medium text-gray-700 shadow-theme-xs transition-colors hover:bg-gray-50 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:border-gray-600 dark:bg-transparent dark:text-gray-300 dark:hover:bg-white/[0.05] dark:hover:text-white sm:w-auto">
                                                    Close
                                                </button>
                                                <button type="submit" disabled="@_isSaving"
                                                        class="flex w-full justify-center rounded-full bg-brand-500 px-6 py-2.5 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900 sm:w-auto">
                                                    @(_editingId.HasValue ? "Update" : "Create")
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>

@code
{
    private readonly List<Bucket> _buckets = new();
    private readonly List<Category> _expenseCategories = new();
    private Dictionary<int, decimal> _spentAmounts = new();
    private bool _isLoading = true;

    private decimal _budgetLimit;
    private decimal _budgetSpent;
    private decimal _totalAllocated;
    private decimal _totalPlanned;

    private bool _showModal;
    private int? _editingId;
    private string _formName = "";
    private decimal _formAllocated;
    private int? _formCategoryId;
    private bool _isSaving;
    private string _formError = "";

    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.UtcNow;

        var settings = await SettingsService.GetAsync();
        _budgetLimit = settings.MonthlyIncome;
        await TransactionService.ApplyAutoDeductionsForBudgetPeriodAsync(settings.MonthStartDay, now);
        await TransactionService.ApplyAutoIncomeForBudgetPeriodAsync(settings.MonthStartDay, settings.MonthlyIncome, now);
        _budgetSpent = await TransactionService.GetExpenseTotalForBudgetPeriodAsync(settings.MonthStartDay, now);

        var categories = await CategoryService.GetAllAsync();
        _expenseCategories.Clear();
        _expenseCategories.AddRange(categories
            .Where(c => c.Scope == CategoryScope.Both || c.Scope == CategoryScope.Expense)
            .OrderBy(c => c.Name));

        await ReloadBucketsAsync();
        _isLoading = false;
    }

    private void OpenCreateModal()
    {
        _editingId = null;
        _formName = "";
        _formAllocated = 0;
        _formCategoryId = _expenseCategories.FirstOrDefault()?.Id;
        _formError = "";
        _showModal = true;
    }

    private void OpenEditModal(Bucket bucket)
    {
        _editingId = bucket.Id;
        _formName = bucket.Name;
        _formAllocated = bucket.AllocatedAmount;
        _formCategoryId = bucket.CategoryId;
        _formError = "";
        _showModal = true;
    }

    private async Task SaveBucketAsync()
    {
        _formError = "";

        if (string.IsNullOrWhiteSpace(_formName))
        {
            _formError = "Bucket name is required.";
            return;
        }

        if (_formAllocated < 0)
        {
            _formError = "Monthly allocation cannot be negative.";
            return;
        }

        if (!_formCategoryId.HasValue)
        {
            _formError = "Please select a category.";
            return;
        }

        _isSaving = true;

        try
        {
            if (_editingId.HasValue)
            {
                var existing = _buckets.FirstOrDefault(b => b.Id == _editingId.Value);
                if (existing is not null)
                {
                    existing.Name = _formName.Trim();
                    existing.AllocatedAmount = _formAllocated;
                    existing.CategoryId = _formCategoryId;
                    await BucketService.UpdateAsync(existing);
                }
            }
            else
            {
                var bucket = new Bucket
                {
                    Name = _formName.Trim(),
                    AllocatedAmount = _formAllocated,
                    CategoryId = _formCategoryId,
                    SortOrder = _buckets.Count,
                };

                await BucketService.CreateAsync(bucket);
            }

            await ReloadBucketsAsync();

            _editingId = null;
            _formName = "";
            _formAllocated = 0;
            _formCategoryId = null;
            _showModal = false;
        }
        catch
        {
            _formError = "Unable to save bucket right now. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void CloseModal()
    {
        _showModal = false;
        _formError = "";
    }

    private async Task DeleteBucketAsync(int id)
    {
        await BucketService.DeleteAsync(id);
        _buckets.RemoveAll(b => b.Id == id);
    }

    private async Task ReloadBucketsAsync()
    {
        var now = DateTime.UtcNow;
        var settings = await SettingsService.GetAsync();
        var items = await BucketService.GetAllAsync();
        _spentAmounts = await BucketService.GetSpentAmountsForPeriodAsync(settings.MonthStartDay, now);
        _buckets.Clear();
        _buckets.AddRange(items);
        _totalAllocated = _buckets.Sum(b => b.AllocatedAmount);
        _totalPlanned = _buckets.Sum(b => Math.Max(0, b.AllocatedAmount - _spentAmounts.GetValueOrDefault(b.Id)));
    }
}
