@page "/categories"
@rendermode InteractiveServer
@using CoinStack.Data.Entities
@inject CoinStack.Services.ICategoryService CategoryService

<PageTitle>Categories</PageTitle>

<div>
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-semibold text-gray-800 dark:text-white/90">Category Management</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage transaction categories used in expense and income logging.</p>
        </div>

        <button
            class="flex h-11 w-11 items-center justify-center rounded-full bg-brand-50 text-brand-600 transition-colors hover:bg-brand-100 dark:bg-brand-500/15 dark:text-brand-400 dark:hover:bg-brand-500/25"
            @onclick="OpenCreateModal"
            title="Add Category">
            <svg class="fill-current" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 4C11.5858 4 11.25 4.33579 11.25 4.75V11.25H4.75C4.33579 11.25 4 11.5858 4 12C4 12.4142 4.33579 12.75 4.75 12.75H11.25V19.25C11.25 19.6642 11.5858 20 12 20C12.4142 20 12.75 19.6642 12.75 19.25V12.75H19.25C19.6642 12.75 20 12.4142 20 12C20 11.5858 19.6642 11.25 19.25 11.25H12.75V4.75C12.75 4.33579 12.4142 4 12 4Z" fill="currentColor"/>
            </svg>
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="text-sm text-gray-500 dark:text-gray-400">Loading...</div>
    }
    else if (_categories.Count == 0)
    {
        <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center dark:border-gray-800 dark:bg-white/[0.03]">
            <p class="mb-4 text-sm text-gray-500 dark:text-gray-400">No categories yet. Create your first category.</p>
            <button
                @onclick="OpenCreateModal"
                class="inline-flex items-center justify-center rounded-full bg-brand-500 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 dark:focus:ring-offset-gray-900">
                Create First Category
            </button>
        </div>
    }
    else
    {
        <div class="rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
            <div class="border-b border-gray-100 px-6 py-5 dark:border-gray-800">
                <h3 class="text-base font-medium text-gray-800 dark:text-white/90">All Categories</h3>
            </div>

            <div class="p-6">
                <div class="overflow-x-auto">
                    <table class="min-w-full">
                        <thead>
                            <tr class="border-b border-gray-100 dark:border-gray-800">
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Name</th>
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Scope</th>
                                <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-400">Color</th>
                                <th class="px-4 py-3 text-right text-sm font-medium text-gray-500 dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
                            @foreach (var category in _categories)
                            {
                                <tr class="transition-colors hover:bg-gray-50 dark:hover:bg-white/[0.02]">
                                    <td class="px-4 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="h-3 w-3 rounded-full" style="background-color: @(category.ColorHex ?? "#6577F3");"></div>
                                            <span class="text-sm font-medium text-gray-800 dark:text-white/90">@category.Name</span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 text-sm text-gray-600 dark:text-gray-300">@category.Scope</td>
                                    <td class="px-4 py-4 text-sm text-gray-600 dark:text-gray-300">@(category.ColorHex ?? "#6577F3")</td>
                                    <td class="px-4 py-4 text-right">
                                        <div class="flex items-center justify-end gap-1">
                                            <button
                                                @onclick="() => OpenEditModal(category)"
                                                class="text-gray-400 transition-colors hover:text-brand-500 dark:hover:text-brand-400"
                                                title="Edit">
                                                <svg class="fill-current" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M15.4901 3.21967C15.783 2.92678 16.2578 2.92678 16.5507 3.21967L20.7807 7.44967C21.0736 7.74256 21.0736 8.21744 20.7807 8.51033L9.53073 19.7603C9.38998 19.9011 9.19912 19.9803 9.00007 19.9803H4.77007C4.35586 19.9803 4.02007 19.6446 4.02007 19.2303V15.0003C4.02007 14.8013 4.09929 14.6104 4.24001 14.4697L15.4901 3.21967ZM5.52007 15.3109V18.4803H8.68951L19.1894 7.98033L16.0201 4.81099L5.52007 15.3109Z" fill="currentColor"/>
                                                </svg>
                                            </button>
                                            <button
                                                @onclick="() => DeleteCategoryAsync(category.Id)"
                                                class="text-gray-400 transition-colors hover:text-error-500 dark:hover:text-error-400"
                                                title="Delete">
                                                <svg class="fill-current" width="16" height="16" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M15.75 4.5H2.25M7.5 8.25V12.75M10.5 8.25V12.75M14.25 4.5V14.25C14.25 15.0784 13.5784 15.75 12.75 15.75H5.25C4.42157 15.75 3.75 15.0784 3.75 14.25V4.5M6 4.5V3C6 2.17157 6.67157 1.5 7.5 1.5H10.5C11.3284 1.5 12 2.17157 12 3V4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (_showModal)
    {
        <div class="fixed inset-0 z-99999 flex items-center justify-center overflow-y-auto p-5 modal-backdrop-enter">
            <div class="fixed inset-0 h-full w-full bg-gray-400/50 backdrop-blur-[32px]" @onclick="CloseModal"></div>
            <div class="relative w-full max-w-[584px] rounded-3xl bg-white p-6 dark:bg-gray-900 lg:p-10 modal-panel-enter">
                <button
                    @onclick="CloseModal"
                    type="button"
                    class="group absolute right-3 top-3 z-999 flex h-9.5 w-9.5 items-center justify-center rounded-full bg-gray-200 text-gray-500 transition-colors hover:bg-gray-300 hover:text-gray-500 dark:bg-gray-800 dark:hover:bg-gray-700 sm:right-6 sm:top-6 sm:h-11 sm:w-11">
                    <svg class="fill-current transition-colors group-hover:text-gray-600 dark:group-hover:text-gray-200" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M6.04289 16.5413C5.65237 16.9318 5.65237 17.565 6.04289 17.9555C6.43342 18.346 7.06658 18.346 7.45711 17.9555L11.9987 13.4139L16.5408 17.956C16.9313 18.3466 17.5645 18.3466 17.955 17.956C18.3455 17.5655 18.3455 16.9323 17.955 16.5418L13.4129 11.9997L17.955 7.4576C18.3455 7.06707 18.3455 6.43391 17.955 6.04338C17.5645 5.65286 16.9313 5.65286 16.5408 6.04338L11.9987 10.5855L7.45711 6.0439C7.06658 5.65338 6.43342 5.65338 6.04289 6.0439C5.65237 6.43442 5.65237 7.06759 6.04289 7.45811L10.5845 11.9997L6.04289 16.5413Z" fill=""/>
                    </svg>
                </button>

                <form @onsubmit="SaveCategoryAsync" @onsubmit:preventDefault="true">
                    <h4 class="mb-6 text-lg font-medium text-gray-800 dark:text-white/90">@(_editingId.HasValue ? "Edit Category" : "New Category")</h4>

                    <div class="space-y-5">
                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Category Name</label>
                            <input
                                type="text"
                                placeholder="e.g. Groceries"
                                @bind="_formName"
                                class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder:text-white/30 dark:focus:border-brand-400" />
                        </div>

                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Color</label>
                            <input
                                type="color"
                                @bind="_formColor"
                                class="peer block h-11 w-full rounded-md border border-gray-300 bg-transparent px-4 py-2 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:focus:border-brand-400" />
                        </div>

                        <div>
                            <label class="mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400">Scope</label>
                            <select
                                @bind="_formScope"
                                class="peer block w-full rounded-md border border-gray-300 bg-transparent px-4 py-3 text-sm text-gray-900 focus:border-brand-600 focus:outline-none focus:ring-0 dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-brand-400">
                                @foreach (var scope in Enum.GetValues<CategoryScope>())
                                {
                                    <option value="@scope">@scope</option>
                                }
                            </select>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_formError))
                        {
                            <div class="rounded-lg border border-error-200 bg-error-50 px-3 py-2 text-sm text-error-700 dark:border-error-500/40 dark:bg-error-500/10 dark:text-error-400">@_formError</div>
                        }
                    </div>

                    <div class="mt-6 flex w-full items-center justify-end gap-3">
                        <button
                            @onclick="CloseModal"
                            type="button"
                            class="flex w-full justify-center rounded-full border border-gray-300 bg-white px-6 py-2.5 text-sm font-medium text-gray-700 shadow-theme-xs transition-colors hover:bg-gray-50 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:border-gray-600 dark:bg-transparent dark:text-gray-300 dark:hover:bg-white/[0.05] dark:hover:text-white sm:w-auto">
                            Close
                        </button>
                        <button
                            type="submit"
                            disabled="@_isSaving"
                            class="flex w-full justify-center rounded-full bg-brand-500 px-6 py-2.5 text-sm font-medium text-white shadow-theme-xs hover:bg-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-60 dark:focus:ring-offset-gray-900 sm:w-auto">
                            @(_editingId.HasValue ? "Update" : "Create")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@code {
    private readonly List<Category> _categories = new();
    private bool _isLoading = true;
    private bool _showModal;
    private bool _isSaving;
    private int? _editingId;
    private string _formName = "";
    private string _formColor = "#6577F3";
    private CategoryScope _formScope = CategoryScope.Both;
    private string _formError = "";

    protected override async Task OnInitializedAsync()
    {
        await ReloadCategoriesAsync();
        _isLoading = false;
    }

    private void OpenCreateModal()
    {
        _editingId = null;
        _formName = "";
        _formColor = "#6577F3";
        _formScope = CategoryScope.Both;
        _formError = "";
        _showModal = true;
    }

    private void OpenEditModal(Category category)
    {
        _editingId = category.Id;
        _formName = category.Name;
        _formColor = category.ColorHex ?? "#6577F3";
        _formScope = category.Scope;
        _formError = "";
        _showModal = true;
    }

    private async Task SaveCategoryAsync()
    {
        _formError = "";

        if (string.IsNullOrWhiteSpace(_formName))
        {
            _formError = "Category name is required.";
            return;
        }

        var trimmedName = _formName.Trim();
        var hasDuplicate = _categories.Any(c =>
            c.Name.Equals(trimmedName, StringComparison.OrdinalIgnoreCase)
            && (!_editingId.HasValue || c.Id != _editingId.Value));

        if (hasDuplicate)
        {
            _formError = "A category with this name already exists.";
            return;
        }

        _isSaving = true;

        try
        {
            if (_editingId.HasValue)
            {
                var existing = _categories.FirstOrDefault(c => c.Id == _editingId.Value);
                if (existing is null)
                {
                    return;
                }

                existing.Name = trimmedName;
                existing.ColorHex = _formColor;
                existing.Scope = _formScope;
                await CategoryService.UpdateAsync(existing);
            }
            else
            {
                var created = await CategoryService.CreateAsync(new Category
                {
                    Name = trimmedName,
                    ColorHex = _formColor,
                    Scope = _formScope,
                });

                _categories.Add(created);
            }

            await ReloadCategoriesAsync();
            CloseModal();
        }
        catch
        {
            _formError = "Unable to save category right now. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteCategoryAsync(int id)
    {
        await CategoryService.DeleteAsync(id);
        _categories.RemoveAll(c => c.Id == id);
    }

    private void CloseModal()
    {
        _showModal = false;
        _formError = "";
    }

    private async Task ReloadCategoriesAsync()
    {
        var items = await CategoryService.GetAllAsync();
        _categories.Clear();
        _categories.AddRange(items.OrderBy(c => c.Name));
    }
}